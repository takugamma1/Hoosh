{% comment %}
  HOOSH — Minimalistic Featured Collection Grid
  Shows all products in a collection (designed for ~4 items)
  PNG-optimized: transparent background, centered product images
  Luxury feel: generous whitespace, refined typography, understated CTA
{% endcomment %}

{% liquid
  assign collection = section.settings.collection
  assign heading = section.settings.heading
  assign description = section.settings.description
  assign cta_label = section.settings.cta_label
  assign columns = section.settings.columns
  assign image_ratio = section.settings.image_ratio
%}

<div
  class="featured-collection-grid color-{{ section.settings.color_scheme }}"
  style="
    --fcg-columns: {{ columns }};
    --fcg-gap: {{ section.settings.grid_gap }}px;
    --fcg-padding-top: {{ section.settings.padding_top }}px;
    --fcg-padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="featured-collection-grid__inner">
    {%- if heading != blank or description != blank -%}
      <div class="featured-collection-grid__header">
        {%- if heading != blank -%}
          <h2 class="featured-collection-grid__title">{{ heading }}</h2>
        {%- endif -%}
        {%- if description != blank -%}
          <p class="featured-collection-grid__description">{{ description }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="featured-collection-grid__grid">
      {%- if collection != blank and collection.products.size > 0 -%}
        {%- for product in collection.products -%}
          <a href="{{ product.url }}" class="featured-collection-grid__item">
            <div class="featured-collection-grid__image-wrap" style="--image-ratio: {{ image_ratio }};">
              {%- if product.featured_image != blank -%}
                <img
                  src="{{ product.featured_image | image_url: width: 800 }}"
                  srcset="
                    {{ product.featured_image | image_url: width: 400 }} 400w,
                    {{ product.featured_image | image_url: width: 600 }} 600w,
                    {{ product.featured_image | image_url: width: 800 }} 800w
                  "
                  sizes="(min-width: 750px) calc(100vw / {{ columns }}), 50vw"
                  alt="{{ product.featured_image.alt | escape }}"
                  loading="lazy"
                  width="{{ product.featured_image.width }}"
                  height="{{ product.featured_image.height }}"
                  class="featured-collection-grid__image"
                >
              {%- else -%}
                <div class="featured-collection-grid__placeholder">
                  {{ 'product-1' | placeholder_svg_tag: 'featured-collection-grid__placeholder-svg' }}
                </div>
              {%- endif -%}
            </div>

            <div class="featured-collection-grid__product-info">
              <h3 class="featured-collection-grid__product-title">{{ product.title }}</h3>
              <span class="featured-collection-grid__product-price">
                {{ product.price | money }}
              </span>
            </div>
          </a>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..4) -%}
          <div class="featured-collection-grid__item featured-collection-grid__item--placeholder">
            <div class="featured-collection-grid__image-wrap" style="--image-ratio: {{ image_ratio }};">
              <div class="featured-collection-grid__placeholder">
                {{ 'product-1' | placeholder_svg_tag: 'featured-collection-grid__placeholder-svg' }}
              </div>
            </div>
            <div class="featured-collection-grid__product-info">
              <h3 class="featured-collection-grid__product-title">Product title</h3>
              <span class="featured-collection-grid__product-price">$0.00</span>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if cta_label != blank and collection != blank -%}
      <div class="featured-collection-grid__cta-wrap">
        <a href="{{ collection.url }}" class="featured-collection-grid__cta">
          {{ cta_label }}
          <span class="featured-collection-grid__cta-arrow" aria-hidden="true">&rarr;</span>
        </a>
      </div>
    {%- endif -%}
  </div>
</div>

{% stylesheet %}
  .featured-collection-grid {
    padding-top: var(--fcg-padding-top);
    padding-bottom: var(--fcg-padding-bottom);
  }

  .featured-collection-grid__inner {
    max-width: var(--page-width);
    margin: 0 auto;
    padding-inline: var(--padding-lg);
  }

  /* ── Header ── */
  .featured-collection-grid__header {
    text-align: center;
    margin-bottom: clamp(40px, 5vw, 72px);
  }

  .featured-collection-grid__title {
    font-family: var(--font-heading--family);
    font-weight: var(--font-heading--weight);
    font-size: clamp(1.5rem, 3vw, 2.5rem);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    margin: 0 0 0.6em;
    color: var(--color-foreground-heading);
    line-height: 1.15;
  }

  .featured-collection-grid__description {
    font-family: var(--font-body--family);
    font-weight: 400;
    font-size: clamp(0.85rem, 1.2vw, 1rem);
    color: var(--color-foreground);
    opacity: 0.7;
    max-width: 520px;
    margin: 0 auto;
    line-height: 1.65;
    letter-spacing: 0.01em;
  }

  /* ── Grid ── */
  .featured-collection-grid__grid {
    display: grid;
    grid-template-columns: repeat(var(--fcg-columns), 1fr);
    gap: var(--fcg-gap);
  }

  @media screen and (max-width: 749px) {
    .featured-collection-grid__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 16px;
    }
  }

  /* ── Item ── */
  .featured-collection-grid__item {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .featured-collection-grid__item:hover .featured-collection-grid__image {
    transform: scale(1.03);
  }

  .featured-collection-grid__item:hover .featured-collection-grid__product-title {
    opacity: 0.6;
  }

  /* ── Image ── */
  .featured-collection-grid__image-wrap {
    position: relative;
    aspect-ratio: var(--image-ratio);
    overflow: hidden;
    background-color: rgb(var(--color-foreground-rgb) / 0.03);
    border-radius: var(--product-corner-radius, 0px);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .featured-collection-grid__image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    padding: 8%;
  }

  .featured-collection-grid__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .featured-collection-grid__placeholder-svg {
    width: 60%;
    height: 60%;
    opacity: 0.15;
  }

  /* ── Product info ── */
  .featured-collection-grid__product-info {
    text-align: center;
    padding: 0 4px;
  }

  .featured-collection-grid__product-title {
    font-family: var(--font-body--family);
    font-weight: 500;
    font-size: clamp(0.8rem, 1vw, 0.95rem);
    letter-spacing: 0.03em;
    text-transform: uppercase;
    margin: 0 0 6px;
    color: var(--color-foreground-heading);
    transition: opacity 0.3s ease;
    line-height: 1.4;
  }

  .featured-collection-grid__product-price {
    font-family: var(--font-body--family);
    font-weight: 400;
    font-size: clamp(0.78rem, 0.95vw, 0.875rem);
    color: var(--color-foreground);
    opacity: 0.55;
    letter-spacing: 0.02em;
  }

  /* ── CTA ── */
  .featured-collection-grid__cta-wrap {
    text-align: center;
    margin-top: clamp(40px, 5vw, 64px);
  }

  .featured-collection-grid__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-body--family);
    font-weight: 400;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-decoration: none;
    color: var(--color-foreground-heading);
    padding: 12px 0;
    border-bottom: 1px solid currentColor;
    transition: opacity 0.3s ease, gap 0.3s ease;
    opacity: 0.8;
  }

  .featured-collection-grid__cta:hover {
    opacity: 1;
    gap: 14px;
  }

  .featured-collection-grid__cta-arrow {
    font-size: 1em;
    transition: transform 0.3s ease;
  }

  .featured-collection-grid__cta:hover .featured-collection-grid__cta-arrow {
    transform: translateX(2px);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Featured Collection Grid",
  "class": "featured-collection-grid-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Collection"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Meticulously crafted essentials for the modern individual."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Call to action text",
      "default": "View Collection"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "1 / 1", "label": "Square" },
        { "value": "3 / 4", "label": "Portrait (3:4)" },
        { "value": "4 / 5", "label": "Portrait (4:5)" },
        { "value": "4 / 3", "label": "Landscape (4:3)" }
      ],
      "default": "3 / 4"
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Grid gap",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom",
      "min": 0,
      "max": 150,
      "step": 5,
      "unit": "px",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Featured Collection Grid",
      "category": "Collection"
    }
  ]
}
{% endschema %}
