{{ 'hoosh-main.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign s = section.settings
  assign uid = section.id
  assign has_header = false
  if s.label != blank or s.heading != blank or s.video_text != blank
    assign has_header = true
  endif
-%}

<section
  id="hcg-{{ uid }}"
  class="hcg"
  data-hoosh
>
  <div class="hcg__glow" aria-hidden="true"></div>

  <div class="h-container hcg__inner">
    {%- if has_header -%}
      <div class="hcg__head h-reveal">
        {%- if s.label != blank -%}<span class="hcg__label">{{ s.label }}</span>{%- endif -%}
        {%- if s.heading != blank -%}<h2 class="hcg__title h-display">{{ s.heading }}</h2>{%- endif -%}
        {%- if s.video_text != blank -%}
          <a
            class="hcg__video"
            {% if s.video_url != blank %}href="{{ s.video_url }}" target="_blank" rel="noopener"{% else %}href="#"{% endif %}
          >
            <span class="hcg__video-icon" aria-hidden="true">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg>
            </span>
            <span>{{ s.video_text }}</span>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="hcg__grid">
        {%- for block in section.blocks -%}
          {%- case block.type -%}

            {%- when 'category' -%}
              <div class="hcg__cell hcg__cell--text" {{ block.shopify_attributes }}>
                {%- if block.settings.heading != blank -%}
                  <h3 class="hcg__cell-title h-display">{{ block.settings.heading }}</h3>
                {%- endif -%}
                {%- if block.settings.description != blank -%}
                  <p class="hcg__cell-desc">{{ block.settings.description }}</p>
                {%- endif -%}
                {%- if block.settings.cta_label != blank -%}
                  <a class="hcg__cell-cta" {% if block.settings.cta_link != blank %}href="{{ block.settings.cta_link }}"{% else %}href="#"{% endif %}>
                    <span>{{ block.settings.cta_label }}</span>
                  </a>
                {%- endif -%}
              </div>

            {%- when 'image' -%}
              <div class="hcg__cell hcg__cell--image{% if block.settings.coming_soon %} is-soon{% endif %}" {{ block.shopify_attributes }}>
                {%- if block.settings.link != blank -%}<a class="hcg__img-link" href="{{ block.settings.link }}">{%- endif -%}
                <div class="hcg__img-wrap">
                  {%- if block.settings.image != blank -%}
                    {{ block.settings.image | image_url: width: 800 | image_tag:
                        loading: 'lazy',
                        widths: '400,600,800,1000',
                        sizes: '(min-width: 1024px) 33vw, (min-width: 768px) 40vw, 80vw',
                        alt: block.settings.image.alt | default: block.settings.caption | default: 'HOOSH'
                    }}
                  {%- else -%}
                    <div class="hcg__img-placeholder">{{ 'product-1' | placeholder_svg_tag }}</div>
                  {%- endif -%}

                  {%- if block.settings.coming_soon -%}
                    <span class="hcg__soon" aria-hidden="true">{{ block.settings.coming_soon_text | default: 'PROXIMAMENTE' }}</span>
                  {%- endif -%}
                </div>
                {%- if block.settings.link != blank -%}</a>{%- endif -%}
              </div>

          {%- endcase -%}
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  #hcg-{{ uid }}.hcg {
    position: relative;
    padding-block: clamp(3rem, 7vw, 6rem);
    background: #000;
    overflow: hidden;
  }
  #hcg-{{ uid }} .hcg__glow {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      radial-gradient(ellipse 50% 35% at 28% 55%, rgba(180, 55, 220, 0.28), transparent 70%),
      radial-gradient(ellipse 45% 30% at 78% 35%, rgba(90, 50, 200, 0.22), transparent 70%),
      radial-gradient(ellipse 40% 30% at 55% 85%, rgba(60, 30, 120, 0.22), transparent 70%);
    z-index: 0;
  }
  #hcg-{{ uid }} .hcg__inner { position: relative; z-index: 1; }

  #hcg-{{ uid }} .hcg__head {
    text-align: center;
    margin-bottom: clamp(2rem, 5vw, 4rem);
  }
  #hcg-{{ uid }} .hcg__label {
    display: inline-block;
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    font-size: 0.72rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #00e38a;
    margin: 0 0 1.2em;
  }
  #hcg-{{ uid }} .hcg__title {
    font-family: var(--h-font-display, 'Bebas Neue', sans-serif);
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.05;
    margin: 0 0 20px;
  }
  #hcg-{{ uid }} .hcg__video {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 8px 16px 8px 8px;
    border-radius: 999px;
    text-decoration: none;
    background: transparent;
    color: #fff;
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    font-size: 0.78rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    transition: transform 0.2s ease, color 0.2s ease;
  }
  #hcg-{{ uid }} .hcg__video:hover { transform: translateY(-1px); color: #00e38a; }
  #hcg-{{ uid }} .hcg__video-icon {
    width: 34px;
    height: 34px;
    border-radius: 50%;
    background: #fff;
    color: #000;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }

  #hcg-{{ uid }} .hcg__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 3vw, 2.5rem) clamp(1.5rem, 3vw, 3rem);
    align-items: center;
  }
  #hcg-{{ uid }} .hcg__cell { min-width: 0; }

  #hcg-{{ uid }} .hcg__cell--text {
    text-align: center;
    padding: clamp(0.5rem, 2vw, 1.5rem) 0;
  }
  #hcg-{{ uid }} .hcg__cell-title {
    font-family: var(--h-font-display, 'Bebas Neue', sans-serif);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1.1;
    margin: 0 0 0.6em;
  }
  #hcg-{{ uid }} .hcg__cell-desc {
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    color: rgba(255, 255, 255, 0.82);
    font-size: 0.95rem;
    line-height: 1.55;
    margin: 0 0 1.4em;
    overflow-wrap: break-word;
  }
  #hcg-{{ uid }} .hcg__cell-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    font-size: 0.78rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #fff;
    text-decoration: none;
    padding-bottom: 4px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.45);
    transition: color 0.2s ease, border-color 0.2s ease, transform 0.2s ease;
  }
  #hcg-{{ uid }} .hcg__cell-cta:hover {
    color: #00e38a;
    border-color: #00e38a;
    transform: translateX(3px);
  }

  #hcg-{{ uid }} .hcg__cell--image {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #hcg-{{ uid }} .hcg__img-link {
    display: block;
    width: 100%;
    text-decoration: none;
  }
  #hcg-{{ uid }} .hcg__img-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1 / 1;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  #hcg-{{ uid }} .hcg__img-link:hover .hcg__img-wrap,
  #hcg-{{ uid }} .hcg__cell--image:hover .hcg__img-wrap {
    transform: translateY(-6px);
  }
  #hcg-{{ uid }} .hcg__img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  #hcg-{{ uid }} .hcg__img-placeholder { width: 40%; opacity: 0.2; }
  #hcg-{{ uid }} .hcg__soon {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%) rotate(-18deg);
    padding: 6px 22px;
    border: 3px solid #ff2e4a;
    border-radius: 6px;
    color: #ff2e4a;
    font-family: var(--h-font-display, 'Bebas Neue', sans-serif);
    font-size: clamp(1rem, 2vw, 1.6rem);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    background: rgba(0, 0, 0, 0.45);
    pointer-events: none;
    white-space: nowrap;
  }

  @media screen and (max-width: 1023px) {
    #hcg-{{ uid }} .hcg__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media screen and (max-width: 600px) {
    #hcg-{{ uid }} .hcg__grid {
      grid-template-columns: 1fr;
      gap: clamp(1.25rem, 4vw, 2rem);
    }
    #hcg-{{ uid }} .hcg__img-wrap { aspect-ratio: 4 / 3; }
    #hcg-{{ uid }} .hcg__img-wrap img {
      max-height: 240px;
    }
  }
</style>

{% schema %}
{
  "name": "HOOSH Catalog Grid",
  "tag": "section",
  "class": "hoosh-section",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "РАЗГЛЕДАЙ"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "НАШИЯТ HOOSH КАТАЛОГ"
    },
    {
      "type": "text",
      "id": "video_text",
      "label": "Video button text",
      "default": "ПРОДУКТОВИ УКАЗАНИЯ"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Video link"
    }
  ],
  "blocks": [
    {
      "type": "category",
      "name": "Category (text)",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "Link text"
        },
        {
          "type": "url",
          "id": "cta_link",
          "label": "Link URL"
        }
      ]
    },
    {
      "type": "image",
      "name": "Image",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link (optional)"
        },
        {
          "type": "checkbox",
          "id": "coming_soon",
          "label": "Show PROXIMAMENTE overlay",
          "default": false
        },
        {
          "type": "text",
          "id": "coming_soon_text",
          "label": "Overlay text",
          "default": "PROXIMAMENTE"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HOOSH Catalog Grid",
      "blocks": [
        { "type": "image" },
        { "type": "category", "settings": { "heading": "HOSE - Маркуч за наргиле", "description": "Последният, но не на последно място по-важност елемент наргиле сета ти.", "cta_label": "Добави Маркуч Към Сета Си" } },
        { "type": "image" },
        { "type": "category", "settings": { "heading": "ВКУСОВЕ", "description": "Открий интензивните и освежаващи вкусове за твоята премиум наргиле сесия.", "cta_label": "Към Всички Вкусове" } },
        { "type": "image" },
        { "type": "category", "settings": { "heading": "НАРГИЛЕТА", "description": "Открий нашата гама наргилета, които предлагат най-доброто изживяване при shisha сесия.", "cta_label": "Към Всички Наргилета" } },
        { "type": "image" },
        { "type": "category", "settings": { "heading": "Е-ГЛАВА", "description": "Персонализирай наргилето си, като избереш любимата си Е-Глава.", "cta_label": "Към Всички Е-Глави" } },
        { "type": "image" }
      ]
    }
  ]
}
{% endschema %}
