{{ 'hoosh-main.css' | asset_url | stylesheet_tag }}

<section class="hfc h-section" data-hoosh>
  <div class="h-container">
    <div class="hfc__grid">
      {%- for block in section.blocks -%}
        <div class="hfc__card h-reveal" {{ block.shopify_attributes }}>
          <div class="hfc__text">
            <span class="hfc__label">{{ block.settings.label }}</span>
            <h3 class="hfc__heading">{{ block.settings.heading }}</h3>
          </div>
          <div class="hfc__media">
            {%- if block.settings.image != blank -%}
              <img
                src="{{ block.settings.image | image_url: width: 800 }}"
                srcset="{{ block.settings.image | image_url: width: 500 }} 500w, {{ block.settings.image | image_url: width: 800 }} 800w"
                sizes="(min-width: 768px) 45vw, 90vw"
                alt="{{ block.settings.heading | escape }}"
                loading="lazy"
              >
            {%- endif -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  </div>
</section>

<style>
  .hfc__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: var(--h-card-gap, 2rem);
  }
  .hfc__card {
    background: var(--h-bg-card, #111);
    border-radius: 16px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    min-height: 500px;
    position: relative;
  }
  .hfc__text {
    padding: clamp(1.5rem, 3vw, 2.5rem);
    flex-shrink: 0;
  }
  .hfc__label {
    font-family: var(--h-font-body);
    font-size: var(--h-small);
    color: var(--h-text-muted, #555);
    text-transform: uppercase;
    letter-spacing: var(--h-tracking-wide);
    display: block;
    margin-bottom: 8px;
  }
  .hfc__heading {
    font-family: var(--h-font-display);
    font-size: clamp(2rem, 4vw, 3.2rem);
    color: var(--h-text);
    text-transform: uppercase;
    letter-spacing: var(--h-tracking-tight);
    line-height: 0.95;
    margin: 0;
  }
  .hfc__media {
    flex: 1;
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: 0 8% 0;
    min-height: 0;
  }
  .hfc__media img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }

  @media screen and (max-width: 767px) {
    .hfc__grid {
      grid-template-columns: 1fr;
    }
    .hfc__card {
      min-height: 380px;
    }
  }
</style>

{% schema %}
{
  "name": "HOOSH Feature Cards",
  "class": "hoosh-section",
  "max_blocks": 4,
  "blocks": [
    {
      "type": "card",
      "name": "Feature card",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label (small text above heading)",
          "default": "Legacy Compatible"
        },
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Works Any Way"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Product image"
        }
      ]
    }
  ],
  "presets": [{
    "name": "HOOSH Feature Cards",
    "blocks": [
      { "type": "card", "settings": { "label": "Legacy Compatible", "heading": "Works Any Way" } },
      { "type": "card", "settings": { "label": "Change Flavours With Ease", "heading": "Switch It Up!" } }
    ]
  }]
}
{% endschema %}
