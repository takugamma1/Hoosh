{{ 'hoosh-main.css' | asset_url | stylesheet_tag }}

<footer class="hf" data-hoosh>
  {%- comment -%} ── Oversized Logo ── {%- endcomment -%}
  <div class="hf__logo-wrap">
    {%- if section.settings.logo != blank -%}
      <img
        class="hf__logo"
        src="{{ section.settings.logo | image_url: width: 1200 }}"
        alt="{{ shop.name }}"
        loading="lazy"
      >
    {%- else -%}
      <span class="hf__logo-text">{{ section.settings.logo_text | default: shop.name }}</span>
    {%- endif -%}
  </div>

  <div class="hf__divider"></div>

  {%- comment -%} ── Main Grid: Nav + Contact + Social ── {%- endcomment -%}
  <div class="hf__grid">
    {%- comment -%} Navigation columns {%- endcomment -%}
    {%- for block in section.blocks -%}
      {%- case block.type -%}

        {%- when 'nav_column' -%}
          <div class="hf__col" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <h4 class="hf__col-title">{{ block.settings.title }}</h4>
            {%- endif -%}
            {%- if block.settings.menu != blank -%}
              <ul class="hf__nav">
                {%- for link in linklists[block.settings.menu].links -%}
                  <li><a href="{{ link.url }}" class="hf__link">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>

        {%- when 'contact' -%}
          <div class="hf__col" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <h4 class="hf__col-title">{{ block.settings.title }}</h4>
            {%- endif -%}
            <ul class="hf__nav">
              {%- if section.settings.whatsapp != blank -%}
                <li>
                  <a href="https://wa.me/{{ section.settings.whatsapp }}" target="_blank" rel="noopener" class="hf__link hf__link--wa">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                    WhatsApp
                  </a>
                </li>
              {%- endif -%}
              {%- if section.settings.telegram != blank -%}
                <li>
                  <a href="https://t.me/{{ section.settings.telegram }}" target="_blank" rel="noopener" class="hf__link hf__link--tg">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 000 12a12 12 0 0012 12 12 12 0 0012-12A12 12 0 0012 0a12 12 0 00-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 01.171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
                    Telegram
                  </a>
                </li>
              {%- endif -%}
              {%- if section.settings.phone != blank -%}
                <li>
                  <a href="tel:{{ section.settings.phone }}" class="hf__link hf__link--ph">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
                    {{ section.settings.phone }}
                  </a>
                </li>
              {%- endif -%}
              {%- if block.settings.email != blank -%}
                <li>
                  <a href="mailto:{{ block.settings.email }}" class="hf__link">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
                    {{ block.settings.email }}
                  </a>
                </li>
              {%- endif -%}
            </ul>
          </div>

        {%- when 'social' -%}
          <div class="hf__col" {{ block.shopify_attributes }}>
            {%- if block.settings.title != blank -%}
              <h4 class="hf__col-title">{{ block.settings.title }}</h4>
            {%- endif -%}
            <div class="hf__socials">
              {%- if block.settings.instagram != blank -%}
                <a href="{{ block.settings.instagram }}" target="_blank" rel="noopener" class="hf__social" aria-label="Instagram">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
                </a>
              {%- endif -%}
              {%- if block.settings.tiktok != blank -%}
                <a href="{{ block.settings.tiktok }}" target="_blank" rel="noopener" class="hf__social" aria-label="TikTok">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/></svg>
                </a>
              {%- endif -%}
              {%- if block.settings.facebook != blank -%}
                <a href="{{ block.settings.facebook }}" target="_blank" rel="noopener" class="hf__social" aria-label="Facebook">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                </a>
              {%- endif -%}
              {%- if block.settings.youtube != blank -%}
                <a href="{{ block.settings.youtube }}" target="_blank" rel="noopener" class="hf__social" aria-label="YouTube">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
                </a>
              {%- endif -%}
              {%- if block.settings.twitter != blank -%}
                <a href="{{ block.settings.twitter }}" target="_blank" rel="noopener" class="hf__social" aria-label="X / Twitter">
                  <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
                </a>
              {%- endif -%}
            </div>
          </div>

      {%- endcase -%}
    {%- endfor -%}
  </div>

  {%- comment -%} ── Bottom Bar ── {%- endcomment -%}
  <div class="hf__divider"></div>
  <div class="hf__bottom">
    <span class="hf__copy">&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</span>
    <div class="hf__policies">
      {%- for policy in shop.policies -%}
        {%- if policy != blank -%}
          <a href="{{ policy.url }}" class="hf__policy-link">{{ policy.title }}</a>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
</footer>

<style>
  /* ── HOOSH Footer ── */
  .hf {
    background: var(--h-bg, #000);
    color: var(--h-text, #fff);
    padding: 0 var(--h-section-px, clamp(1rem, 5vw, 4rem));
    overflow: hidden;
  }

  /* Oversized logo */
  .hf__logo-wrap {
    text-align: center;
    padding: clamp(3rem, 8vw, 6rem) 0 clamp(2rem, 4vw, 3rem);
    overflow: hidden;
  }
  .hf__logo {
    max-width: min(90vw, 800px);
    height: auto;
    opacity: 0.9;
    display: inline-block;
  }
  .hf__logo-text {
    font-family: var(--h-font-display, 'Bebas Neue', sans-serif);
    font-size: clamp(5rem, 18vw, 16rem);
    letter-spacing: 0.05em;
    line-height: 0.85;
    color: var(--h-text, #fff);
    opacity: 0.12;
    display: block;
    text-transform: uppercase;
    user-select: none;
  }

  /* Divider */
  .hf__divider {
    height: 1px;
    background: var(--h-border-accent, #333);
    width: 100%;
  }

  /* Main grid */
  .hf__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: clamp(2rem, 4vw, 4rem);
    max-width: var(--h-max-width, 1200px);
    margin: 0 auto;
    padding: clamp(2.5rem, 5vw, 4rem) 0;
  }

  /* Column */
  .hf__col-title {
    font-family: var(--h-font-display, 'Bebas Neue', sans-serif);
    font-size: 1.1rem;
    letter-spacing: var(--h-tracking-wide, 0.15em);
    text-transform: uppercase;
    color: var(--h-text, #fff);
    margin: 0 0 1.25rem;
  }

  /* Nav list */
  .hf__nav {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .hf__link {
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    font-size: var(--h-small, 0.85rem);
    color: var(--h-text-secondary, #888);
    text-decoration: none;
    transition: color 0.25s ease;
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }
  .hf__link:hover {
    color: var(--h-pink, #FF1493);
  }
  .hf__link--wa:hover { color: var(--h-whatsapp, #25D366); }
  .hf__link--tg:hover { color: var(--h-telegram, #0088cc); }
  .hf__link--ph:hover { color: var(--h-green, #00E676); }

  /* Social icons */
  .hf__socials {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
  }
  .hf__social {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    border: 1px solid var(--h-border-accent, #333);
    color: var(--h-text-secondary, #888);
    transition: all 0.3s ease;
  }
  .hf__social:hover {
    color: var(--h-pink, #FF1493);
    border-color: var(--h-pink, #FF1493);
    transform: translateY(-2px);
  }

  /* Bottom bar */
  .hf__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    padding: 1.5rem 0 2rem;
    max-width: var(--h-max-width, 1200px);
    margin: 0 auto;
  }
  .hf__copy {
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    font-size: 0.75rem;
    color: var(--h-text-muted, #555);
  }
  .hf__policies {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }
  .hf__policy-link {
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    font-size: 0.75rem;
    color: var(--h-text-muted, #555);
    text-decoration: none;
    transition: color 0.25s ease;
  }
  .hf__policy-link:hover {
    color: var(--h-text-secondary, #888);
  }

  /* ── Mobile ── */
  @media screen and (max-width: 767px) {
    .hf__logo-text {
      font-size: clamp(4rem, 22vw, 8rem);
    }
    .hf__grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
    .hf__bottom {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
    .hf__policies {
      justify-content: center;
    }
  }

  @media screen and (max-width: 480px) {
    .hf__grid {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .hf__col-title {
      margin-bottom: 1rem;
    }
    .hf__nav {
      align-items: center;
    }
    .hf__socials {
      justify-content: center;
    }
  }
</style>

{% schema %}
{
  "name": "HOOSH Footer",
  "class": "hoosh-footer-section",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image",
      "info": "Upload a large logo. Leave empty to show the store name as oversized text."
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo fallback text",
      "default": "HOOSH",
      "info": "Shown as oversized text when no logo image is set."
    },
    {
      "type": "header",
      "content": "Contact"
    },
    {
      "type": "text",
      "id": "whatsapp",
      "label": "WhatsApp number",
      "info": "International format, no + sign"
    },
    {
      "type": "text",
      "id": "telegram",
      "label": "Telegram handle",
      "info": "Without @"
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number",
      "info": "With country code"
    }
  ],
  "blocks": [
    {
      "type": "nav_column",
      "name": "Navigation",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Column title",
          "default": "Navigation"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    },
    {
      "type": "contact",
      "name": "Contact info",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Column title",
          "default": "Contact"
        },
        {
          "type": "text",
          "id": "email",
          "label": "Email address"
        }
      ]
    },
    {
      "type": "social",
      "name": "Social links",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Column title",
          "default": "Follow Us"
        },
        {
          "type": "url",
          "id": "instagram",
          "label": "Instagram URL"
        },
        {
          "type": "url",
          "id": "tiktok",
          "label": "TikTok URL"
        },
        {
          "type": "url",
          "id": "facebook",
          "label": "Facebook URL"
        },
        {
          "type": "url",
          "id": "youtube",
          "label": "YouTube URL"
        },
        {
          "type": "url",
          "id": "twitter",
          "label": "X / Twitter URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "HOOSH Footer",
      "blocks": [
        {
          "type": "nav_column",
          "settings": { "title": "Shop", "menu": "main-menu" }
        },
        {
          "type": "nav_column",
          "settings": { "title": "Info", "menu": "footer" }
        },
        {
          "type": "contact",
          "settings": { "title": "Contact" }
        },
        {
          "type": "social",
          "settings": { "title": "Follow Us" }
        }
      ]
    }
  ]
}
{% endschema %}
