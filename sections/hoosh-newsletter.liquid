{{ 'hoosh-main.css' | asset_url | stylesheet_tag }}

<section class="hns h-section" data-hoosh>
  <div class="h-container">
    <div class="hns__card">
      <div class="hns__text">
        {%- if section.settings.label != blank -%}
          <span class="hns__label">{{ section.settings.label }}</span>
        {%- endif -%}
        <h2 class="hns__heading">{{ section.settings.heading | default: 'Не пропускай последните ни новини' }}</h2>
      </div>

      <div class="hns__form">
        {% form 'customer', class: 'hns__shopify-form' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div class="hns__input-wrap">
            <input
              type="email"
              name="contact[email]"
              class="hns__input"
              placeholder="{{ section.settings.placeholder | default: 'Email' }}"
              aria-label="Email"
              required
            >
            <button type="submit" class="hns__btn">
              {{ section.settings.button_label | default: 'Абониране' }}
            </button>
          </div>

          {%- if form.posted_successfully? -%}
            <p class="hns__success">{{ section.settings.success_message | default: 'Благодарим ти, абонаментът е активиран!' }}</p>
          {%- endif -%}
          {%- if form.errors -%}
            <p class="hns__error">{{ form.errors | default_errors }}</p>
          {%- endif -%}
        {% endform %}
      </div>
    </div>
  </div>
</section>

<style>
  .hns__card {
    background: var(--h-bg-elevated, #0a0a0a);
    border: 1px solid var(--h-border, #1a1a1a);
    border-radius: 16px;
    padding: clamp(1.75rem, 4vw, 3rem);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1.5rem, 4vw, 3rem);
    align-items: center;
  }
  .hns__label {
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    font-size: var(--h-small, 0.85rem);
    color: var(--h-text-secondary, #888);
    text-transform: none;
    letter-spacing: 0.02em;
    display: block;
    margin-bottom: 0.5rem;
  }
  .hns__heading {
    font-family: var(--h-font-display, 'Bebas Neue', sans-serif);
    font-size: clamp(1.75rem, 3.5vw, 2.75rem);
    color: var(--h-text, #fff);
    text-transform: none;
    letter-spacing: 0.01em;
    line-height: 1.1;
    margin: 0;
  }
  .hns__input-wrap {
    position: relative;
    display: flex;
    align-items: center;
    background: var(--h-bg-card, #111);
    border: 1px solid var(--h-border-accent, #333);
    border-radius: 999px;
    padding: 4px 4px 4px 20px;
    gap: 8px;
  }
  .hns__input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    font-size: 0.95rem;
    color: var(--h-text, #fff);
    padding: 12px 0;
  }
  .hns__input::placeholder {
    color: var(--h-text-muted, #666);
  }
  .hns__btn {
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #fff;
    background: linear-gradient(90deg, #ff4e7e 0%, #e84a7a 35%, #8a5bff 100%);
    border: none;
    border-radius: 999px;
    padding: 14px 28px;
    cursor: pointer;
    transition: transform 0.2s ease, filter 0.2s ease;
    white-space: nowrap;
  }
  .hns__btn:hover {
    filter: brightness(1.08);
    transform: translateY(-1px);
  }
  .hns__success {
    margin: 12px 0 0;
    color: var(--h-green, #00E676);
    font-size: 0.85rem;
  }
  .hns__error {
    margin: 12px 0 0;
    color: #ff6b6b;
    font-size: 0.85rem;
  }

  @media screen and (max-width: 767px) {
    .hns__card {
      grid-template-columns: 1fr;
      text-align: left;
    }
    .hns__input-wrap {
      flex-wrap: wrap;
      border-radius: 20px;
      padding: 6px;
    }
    .hns__input {
      padding-left: 14px;
      width: 100%;
    }
    .hns__btn {
      width: 100%;
    }
  }
</style>

{% schema %}
{
  "name": "HOOSH Newsletter",
  "class": "hoosh-newsletter-section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label above heading",
      "default": "Абонирай се за нашия бюлетин"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Не пропускай последните ни новини"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "Email"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Абониране"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Благодарим ти, абонаментът е активиран!"
    }
  ],
  "presets": [{ "name": "HOOSH Newsletter" }]
}
{% endschema %}
