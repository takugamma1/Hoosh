{{ 'hoosh-main.css' | asset_url | stylesheet_tag }}

<section id="hoosh-products" class="h-section" data-hoosh style="--hoosh-grid-cols: {{ section.settings.columns | default: 4 }};">
  <div class="h-container">
    <div class="hoosh-grid__header h-reveal" style="text-align:center;">
      {%- if section.settings.label != blank -%}
        <span class="h-label">{{ section.settings.label }}</span>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <span class="hoosh-grid__subheading">{{ section.settings.subheading }}</span>
      {%- endif -%}
      <h2 class="h-display" style="font-size: var(--h-section-title);">{{ section.settings.heading | default: 'Choose Your Head' }}</h2>
    </div>

    <div class="hoosh-grid">
      {%- if section.settings.collection != blank -%}
        {%- assign bundle_col = section.settings.bundle_collection -%}
        {%- for product in section.settings.collection.products limit: section.settings.max_products -%}
          {%- assign bundle_product = nil -%}
          {%- if bundle_col != blank -%}
            {%- assign bundle_product = bundle_col.products[forloop.index0] -%}
          {%- endif -%}
          {% render 'hoosh-product-card',
            product: product,
            bundle_product: bundle_product,
            bundle_label: section.settings.bundle_label
          %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..3) -%}
          {% render 'hoosh-product-card' %}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .hoosh-grid__header {
    text-align: center;
    margin-bottom: clamp(2rem, 5vw, 4rem);
  }
  .hoosh-grid {
    display: grid;
    grid-template-columns: repeat(var(--hoosh-grid-cols, 4), 1fr);
    gap: var(--h-card-gap);
  }
  @media screen and (max-width: 1023px) {
    .hoosh-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media screen and (max-width: 767px) {
    .hoosh-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media screen and (max-width: 480px) {
    .hoosh-grid {
      grid-template-columns: 1fr;
      max-width: 360px;
      margin: 0 auto;
    }
  }
  .hoosh-grid__header .h-label {
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 999px;
    padding: 6px 16px;
    display: inline-block;
    color: rgba(255,255,255,0.85);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 0 0 1.5em;
  }
  .hoosh-grid__subheading {
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    font-size: 0.75rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    margin: 0 0 1em;
    display: block;
  }
</style>

{% schema %}
{
  "name": "HOOSH Product Grid",
  "class": "hoosh-section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Category label",
      "default": "The Heads"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Small caption (above heading)",
      "default": ""
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Choose Your Head"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max products",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Columns (desktop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "header",
      "content": "Bundle pairing (optional)"
    },
    {
      "type": "collection",
      "id": "bundle_collection",
      "label": "Bundle collection",
      "info": "If set, each product is paired with a bundle at the same position. Leave empty for items without bundles."
    },
    {
      "type": "text",
      "id": "bundle_label",
      "label": "Bundle label",
      "default": "Pack of 10",
      "info": "Label shown on the toggle inside the product view."
    }
  ],
  "presets": [{ "name": "HOOSH Product Grid" }]
}
{% endschema %}
