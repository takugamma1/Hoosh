<section id="hoosh-products" class="h-section" data-hoosh>
  <div class="h-container">
    <div class="hoosh-grid__header h-reveal">
      <span class="h-label">{{ section.settings.label | default: 'The Heads' }}</span>
      <h2 class="h-display" style="font-size: var(--h-section-title);">{{ section.settings.heading | default: 'Choose Your Head' }}</h2>
    </div>

    <div class="hoosh-grid">
      {%- if section.settings.collection != blank -%}
        {%- for product in section.settings.collection.products limit: section.settings.max_products -%}
          {% render 'hoosh-product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..3) -%}
          {% render 'hoosh-product-card' %}
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .hoosh-grid__header {
    text-align: center;
    margin-bottom: clamp(2rem, 5vw, 4rem);
  }
  .hoosh-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--h-card-gap);
  }
  @media screen and (max-width: 1023px) {
    .hoosh-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media screen and (max-width: 767px) {
    .hoosh-grid {
      grid-template-columns: 1fr;
      max-width: 400px;
      margin: 0 auto;
    }
  }
</style>

{% schema %}
{
  "name": "HOOSH Product Grid",
  "class": "hoosh-section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Category label",
      "default": "The Heads"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Choose Your Head"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max products",
      "min": 2,
      "max": 12,
      "step": 1,
      "default": 6
    }
  ],
  "presets": [{ "name": "HOOSH Product Grid" }]
}
{% endschema %}
