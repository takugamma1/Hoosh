{{ 'hoosh-main.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign label_v = section.settings.label | default: '' | strip
  assign sub_v = section.settings.subheading | default: '' | strip
  assign head_v = section.settings.heading | default: '' | strip
  assign has_label = false
  assign has_sub = false
  assign has_head = false
  if label_v != '' and label_v != blank
    assign has_label = true
  endif
  if sub_v != '' and sub_v != blank
    assign has_sub = true
  endif
  if head_v != '' and head_v != blank
    assign has_head = true
  endif
  assign has_header = false
  if has_label or has_sub or has_head
    assign has_header = true
  endif
  if section.settings.hide_header
    assign has_header = false
    assign has_label = false
    assign has_sub = false
    assign has_head = false
  endif
  assign cols_desktop = section.settings.columns | default: 4
  assign cols_mobile = 2
-%}

<section
  id="hpc-{{ section.id }}"
  class="hpc-section{% unless has_header %} hpc-section--no-header{% endunless %}"
  style="--hpc-cols-desktop: {{ cols_desktop }}; --hpc-cols-mobile: {{ cols_mobile }};"
  data-hoosh
  data-hpc-build="2026-04-22-carousel-v2"
>
  <div style="background:#ff0059;color:#fff;padding:14px;text-align:center;font-weight:700;letter-spacing:.08em;font-family:sans-serif;">
    HPC CAROUSEL BUILD 2026-04-22 v2 — if you can read this, the new section IS being served.
  </div>
  <div class="h-container">
    {%- if has_header -%}
      <div class="hpc-header h-reveal">
        {%- if has_label -%}<span class="hpc-header__label">{{ label_v }}</span>{%- endif -%}
        {%- if has_sub -%}<span class="hpc-header__sub">{{ sub_v }}</span>{%- endif -%}
        {%- if has_head -%}<h2 class="hpc-header__title h-display">{{ head_v }}</h2>{%- endif -%}
      </div>
    {%- endif -%}

    <div class="hpc-carousel" data-hpc data-cols-desktop="{{ cols_desktop }}" data-cols-mobile="{{ cols_mobile }}">
      <button type="button" class="hpc-arrow hpc-arrow--prev" data-dir="prev" aria-label="Previous products">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>

      <div class="hpc-viewport">
        <ul class="hpc-track" data-hpc-track>
          {%- if section.settings.collection != blank -%}
            {%- for product in section.settings.collection.products limit: section.settings.max_products -%}
              <li class="hpc-slide">
                {% render 'hoosh-product-card', product: product %}
              </li>
            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..4) -%}
              <li class="hpc-slide">
                {% render 'hoosh-product-card' %}
              </li>
            {%- endfor -%}
          {%- endif -%}
        </ul>
      </div>

      <button type="button" class="hpc-arrow hpc-arrow--next" data-dir="next" aria-label="Next products">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
  </div>
</section>

<style>
  .hpc-section {
    padding-block-start: clamp(3rem, 7vw, 6rem);
    padding-block-end: clamp(3rem, 7vw, 6rem);
  }
  .hpc-section--no-header {
    padding-block-start: clamp(0.75rem, 2vw, 1.5rem);
    padding-block-end: clamp(0.75rem, 2vw, 1.5rem);
  }

  .hpc-header {
    text-align: center;
    margin-bottom: clamp(2rem, 5vw, 4rem);
  }
  .hpc-header__label {
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 999px;
    padding: 6px 16px;
    display: inline-block;
    color: rgba(255,255,255,0.85);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 0 0 1.5em;
  }
  .hpc-header__sub {
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    font-size: 0.75rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    margin: 0 0 1em;
    display: block;
  }
  .hpc-header__title {
    font-size: var(--h-section-title);
    margin: 0;
  }

  .hpc-carousel {
    position: relative;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .hpc-viewport {
    flex: 1 1 auto;
    min-width: 0;
    overflow: hidden;
  }
  .hpc-track {
    display: flex;
    gap: 1.5rem;
    margin: 0;
    padding: 4px 4px 24px;
    list-style: none;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
  }
  .hpc-track::-webkit-scrollbar { display: none; }
  .hpc-slide {
    flex: 0 0 calc((100% - (var(--hpc-cols-desktop, 4) - 1) * 1.5rem) / var(--hpc-cols-desktop, 4));
    scroll-snap-align: start;
  }
  .hpc-arrow {
    flex: 0 0 44px;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.15);
    color: #fff;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .hpc-arrow:hover {
    background: rgba(255, 255, 255, 0.16);
    transform: scale(1.05);
  }

  @media screen and (max-width: 767px) {
    .hpc-arrow { display: none; }
    .hpc-track { gap: 1rem; padding-bottom: 16px; }
    .hpc-slide {
      flex: 0 0 calc((100% - (var(--hpc-cols-mobile, 2) - 1) * 1rem) / var(--hpc-cols-mobile, 2));
    }
  }
</style>

<script>
  (function () {
    document.querySelectorAll('[data-hpc]').forEach(function (root) {
      var track = root.querySelector('[data-hpc-track]');
      if (!track) return;
      var colsDesktop = parseInt(root.getAttribute('data-cols-desktop'), 10) || 4;
      var colsMobile = parseInt(root.getAttribute('data-cols-mobile'), 10) || 2;

      function visibleCols() {
        return window.matchMedia('(max-width: 767px)').matches ? colsMobile : colsDesktop;
      }

      function stepDistance() {
        var slide = track.querySelector('.hpc-slide');
        if (!slide) return track.clientWidth;
        var style = getComputedStyle(track);
        var gap = parseFloat(style.columnGap || style.gap || 0) || 24;
        var w = slide.getBoundingClientRect().width;
        return (w + gap) * visibleCols();
      }

      root.querySelectorAll('[data-dir]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var dir = btn.getAttribute('data-dir') === 'next' ? 1 : -1;
          track.scrollBy({ left: dir * stepDistance(), behavior: 'smooth' });
        });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "HOOSH Product Grid",
  "class": "hoosh-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "hide_header",
      "label": "Hide header (hard-override)",
      "default": false,
      "info": "Force-hides label, caption and heading even if text is entered."
    },
    {
      "type": "text",
      "id": "label",
      "label": "Category label",
      "default": ""
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Small caption (above heading)",
      "default": ""
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": ""
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max products",
      "min": 2,
      "max": 16,
      "step": 1,
      "default": 8,
      "info": "Total number of products loaded into the carousel."
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Products per row (desktop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4,
      "info": "How many products are visible at once on desktop. Mobile always shows 2 and advances 2 at a time."
    }
  ],
  "presets": [{ "name": "HOOSH Product Grid" }]
}
{% endschema %}
