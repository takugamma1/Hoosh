{{ 'hoosh-main.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign label_v = section.settings.label | default: '' | strip
  assign sub_v = section.settings.subheading | default: '' | strip
  assign head_v = section.settings.heading | default: '' | strip
  assign has_label = false
  assign has_sub = false
  assign has_head = false
  if label_v != '' and label_v != blank
    assign has_label = true
  endif
  if sub_v != '' and sub_v != blank
    assign has_sub = true
  endif
  if head_v != '' and head_v != blank
    assign has_head = true
  endif
  assign has_header = false
  if has_label or has_sub or has_head
    assign has_header = true
  endif
  if section.settings.hide_header
    assign has_header = false
    assign has_label = false
    assign has_sub = false
    assign has_head = false
  endif
  assign cols = section.settings.columns | default: 4
  assign mobile_cols = 2
-%}

<section
  id="hoosh-products-{{ section.id }}"
  class="h-section hoosh-grid-section{% unless has_header %} hoosh-grid-section--no-header{% endunless %}"
  data-hoosh
  style="--hoosh-grid-cols: {{ cols }}; --hoosh-grid-cols-mobile: {{ mobile_cols }};"
>
  <div class="h-container">
    {%- if has_header -%}
      <div class="hoosh-grid__header h-reveal" style="text-align:center;">
        {%- if has_label -%}
          <span class="h-label">{{ label_v }}</span>
        {%- endif -%}
        {%- if has_sub -%}
          <span class="hoosh-grid__subheading">{{ sub_v }}</span>
        {%- endif -%}
        {%- if has_head -%}
          <h2 class="h-display" style="font-size: var(--h-section-title);">{{ head_v }}</h2>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="hoosh-carousel" data-hoosh-carousel data-cols-desktop="{{ cols }}" data-cols-mobile="{{ mobile_cols }}">
      <button type="button" class="hoosh-carousel__arrow hoosh-carousel__arrow--prev" data-dir="prev" aria-label="Previous">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <div class="hoosh-carousel__track" data-track>
        {%- if section.settings.collection != blank -%}
          {%- for product in section.settings.collection.products limit: section.settings.max_products -%}
            <div class="hoosh-carousel__slide">
              {% render 'hoosh-product-card', product: product %}
            </div>
          {%- endfor -%}
        {%- else -%}
          {%- for i in (1..4) -%}
            <div class="hoosh-carousel__slide">
              {% render 'hoosh-product-card' %}
            </div>
          {%- endfor -%}
        {%- endif -%}
      </div>
      <button type="button" class="hoosh-carousel__arrow hoosh-carousel__arrow--next" data-dir="next" aria-label="Next">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
  </div>
</section>

<style>
  .hoosh-grid-section {
    padding-block-start: clamp(3rem, 7vw, 6rem);
    padding-block-end: clamp(3rem, 7vw, 6rem);
  }
  .hoosh-grid-section--no-header {
    padding-block-start: clamp(0.75rem, 2vw, 1.5rem);
    padding-block-end: clamp(0.75rem, 2vw, 1.5rem);
  }
  .hoosh-grid__header {
    text-align: center;
    margin-bottom: clamp(2rem, 5vw, 4rem);
  }
  .hoosh-grid__header .h-label {
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 999px;
    padding: 6px 16px;
    display: inline-block;
    color: rgba(255,255,255,0.85);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 0 0 1.5em;
  }
  .hoosh-grid__subheading {
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    font-size: 0.75rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.55);
    margin: 0 0 1em;
    display: block;
  }

  /* Carousel */
  .hoosh-carousel {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 8px;
  }
  .hoosh-carousel__track {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: calc((100% - (var(--hoosh-grid-cols, 4) - 1) * var(--h-card-gap, 1.5rem)) / var(--hoosh-grid-cols, 4));
    gap: var(--h-card-gap, 1.5rem);
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
    padding: 4px 4px 24px;
  }
  .hoosh-carousel__track::-webkit-scrollbar { display: none; }
  .hoosh-carousel__slide {
    scroll-snap-align: start;
  }
  .hoosh-carousel__arrow {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: #fff;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: background 0.2s ease, transform 0.2s ease;
    flex: none;
  }
  .hoosh-carousel__arrow:hover { background: rgba(255, 255, 255, 0.12); transform: scale(1.05); }

  @media screen and (max-width: 1023px) {
    .hoosh-carousel__track {
      grid-auto-columns: calc((100% - 2 * var(--h-card-gap, 1.5rem)) / 3);
    }
  }
  @media screen and (max-width: 767px) {
    .hoosh-carousel {
      grid-template-columns: 1fr;
    }
    .hoosh-carousel__arrow { display: none; }
    .hoosh-carousel__track {
      grid-auto-columns: calc((100% - 1rem) / var(--hoosh-grid-cols-mobile, 2));
      gap: 1rem;
    }
  }
</style>

<script>
  (function () {
    document.querySelectorAll('[data-hoosh-carousel]').forEach(function (root) {
      var track = root.querySelector('[data-track]');
      if (!track) return;
      var colsDesktop = parseInt(root.getAttribute('data-cols-desktop'), 10) || 4;
      var colsMobile = parseInt(root.getAttribute('data-cols-mobile'), 10) || 2;
      function visibleCols() {
        if (window.matchMedia('(max-width: 767px)').matches) return colsMobile;
        if (window.matchMedia('(max-width: 1023px)').matches) return Math.min(colsDesktop, 3);
        return colsDesktop;
      }
      root.querySelectorAll('[data-dir]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var dir = btn.getAttribute('data-dir') === 'next' ? 1 : -1;
          var slide = track.querySelector('.hoosh-carousel__slide');
          var gap = parseFloat(getComputedStyle(track).columnGap) || 24;
          var slideW = slide ? slide.getBoundingClientRect().width : 300;
          var n = visibleCols();
          track.scrollBy({ left: dir * (slideW + gap) * n, behavior: 'smooth' });
        });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "HOOSH Product Grid",
  "class": "hoosh-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "hide_header",
      "label": "Hide header (hard-override)",
      "default": false,
      "info": "Force-hides label, caption and heading even if text is entered."
    },
    {
      "type": "text",
      "id": "label",
      "label": "Category label",
      "default": ""
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Small caption (above heading)",
      "default": ""
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": ""
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max products",
      "min": 2,
      "max": 16,
      "step": 1,
      "default": 8,
      "info": "Total products loaded into the carousel."
    },
    {
      "type": "range",
      "id": "columns",
      "label": "Products per row (desktop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4,
      "info": "How many products are visible at once on desktop. Mobile always shows 2."
    }
  ],
  "presets": [{ "name": "HOOSH Product Grid" }]
}
{% endschema %}
