{{ 'hoosh-main.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign p = product
  assign coming_soon = false
  if p.tags contains 'coming-soon' or p.tags contains 'ochakvai-skoro'
    assign coming_soon = true
  endif
-%}

<section class="hpp h-section" data-hoosh>
  <div class="h-container">
    {%- if section.settings.show_breadcrumbs -%}
      <nav class="hpp__crumbs" aria-label="breadcrumb">
        <a href="{{ routes.root_url }}">Начало</a>
        <span aria-hidden="true">/</span>
        {%- if collection -%}
          <a href="{{ collection.url }}">{{ collection.title }}</a>
          <span aria-hidden="true">/</span>
        {%- endif -%}
        <span aria-current="page">{{ p.title }}</span>
      </nav>
    {%- endif -%}

    <div class="hpp__grid">
      <div class="hpp__gallery">
        {%- assign featured = p.featured_image -%}
        <div class="hpp__media hpp__media--main" data-main>
          {%- if featured != blank -%}
            <img
              src="{{ featured | image_url: width: 1200 }}"
              srcset="{{ featured | image_url: width: 600 }} 600w, {{ featured | image_url: width: 1200 }} 1200w"
              sizes="(min-width: 768px) 50vw, 90vw"
              alt="{{ featured.alt | default: p.title | escape }}"
              width="{{ featured.width }}"
              height="{{ featured.height }}"
              loading="eager"
            >
          {%- else -%}
            <div class="hpp__placeholder">{{ 'product-1' | placeholder_svg_tag }}</div>
          {%- endif -%}
          {%- if coming_soon -%}
            <span class="hpp__soon">Очаквай Скоро</span>
          {%- endif -%}
        </div>

        {%- if p.images.size > 1 -%}
          <div class="hpp__thumbs">
            {%- for img in p.images -%}
              <button
                type="button"
                class="hpp__thumb{% if forloop.first %} is-active{% endif %}"
                data-thumb
                data-src="{{ img | image_url: width: 1200 }}"
                aria-label="Image {{ forloop.index }}"
              >
                <img
                  src="{{ img | image_url: width: 200 }}"
                  alt=""
                  width="120"
                  height="120"
                  loading="lazy"
                >
              </button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <div class="hpp__details">
        <h1 class="hpp__title">{{ p.title }}</h1>

        {%- if coming_soon -%}
          <div class="hpp__price hpp__price--soon">Очаквай Скоро</div>
        {%- endif -%}

        {%- if p.description != blank -%}
          <div class="hpp__desc">{{ p.description }}</div>
        {%- endif -%}

        {%- if p.has_only_default_variant == false and coming_soon == false -%}
          {%- for option in p.options_with_values -%}
            <div class="hpp__option">
              <div class="hpp__option-label">{{ option.name }}</div>
              <div class="hpp__swatches">
                {%- for value in option.values -%}
                  <span class="hpp__swatch{% if option.selected_value == value %} is-active{% endif %}">{{ value }}</span>
                {%- endfor -%}
              </div>
            </div>
          {%- endfor -%}
        {%- endif -%}

        {%- liquid
          assign phone_tel = section.settings.phone | default: settings.hoosh_phone
          assign phone_display = section.settings.phone_display | default: settings.hoosh_phone_display | default: phone_tel
          assign wa = section.settings.whatsapp | default: settings.hoosh_whatsapp
          assign call_label = section.settings.call_label | default: 'Обади се'
          assign wa_label = section.settings.wa_label | default: 'Поръчай през уатсапп'
          assign wa_text = 'Здравейте, интересувам се от: ' | append: p.title
        -%}

        <div class="hpp__widgets">
          {%- if phone_tel != blank -%}
            <a href="tel:{{ phone_tel | replace: ' ', '' }}" class="hpp__widget hpp__widget--call">
              <span class="hpp__widget-icon" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92z"/></svg>
              </span>
              <span class="hpp__widget-text">
                <span class="hpp__widget-title">{{ call_label }}</span>
                <span class="hpp__widget-sub">{{ phone_display }}</span>
              </span>
            </a>
          {%- endif -%}

          {%- if wa != blank -%}
            <a
              href="https://wa.me/{{ wa }}?text={{ wa_text | url_encode }}"
              target="_blank"
              rel="noopener"
              class="hpp__widget hpp__widget--wa"
            >
              <span class="hpp__widget-icon" aria-hidden="true">
                <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              </span>
              <span class="hpp__widget-text">
                <span class="hpp__widget-title">{{ wa_label }}</span>
                <span class="hpp__widget-sub">WhatsApp</span>
              </span>
            </a>
          {%- endif -%}
        </div>

        {%- if phone_tel == blank and wa == blank -%}
          <p class="hpp__empty-hint">Добави телефон и WhatsApp в настройките на секцията, за да се покажат бутоните.</p>
        {%- endif -%}

        {%- if section.settings.show_meta -%}
          <div class="hpp__meta">
            {%- if p.type != blank -%}
              <div><strong>Категория:</strong> {{ p.type }}</div>
            {%- endif -%}
            {%- if p.vendor != blank -%}
              <div><strong>Марка:</strong> {{ p.vendor }}</div>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  .hpp {
    padding-block: clamp(2rem, 5vw, 4rem);
  }
  .hpp__crumbs {
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    font-size: 0.8rem;
    color: rgba(255, 255, 255, 0.55);
    margin-bottom: clamp(1.5rem, 3vw, 2.5rem);
    letter-spacing: 0.04em;
  }
  .hpp__crumbs a { color: rgba(255, 255, 255, 0.8); text-decoration: none; }
  .hpp__crumbs a:hover { color: #fff; }
  .hpp__crumbs span[aria-hidden] { margin: 0 8px; opacity: 0.45; }

  .hpp__grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }
  @media screen and (max-width: 767px) {
    .hpp__grid { grid-template-columns: 1fr; }
  }

  .hpp__gallery { position: sticky; top: 80px; }
  @media screen and (max-width: 767px) { .hpp__gallery { position: static; } }

  .hpp__media {
    position: relative;
    border-radius: 20px;
    overflow: hidden;
    aspect-ratio: 1 / 1;
    background:
      radial-gradient(ellipse at 50% 75%, rgba(165, 75, 200, 0.4), transparent 65%),
      radial-gradient(ellipse at 50% 30%, rgba(60, 30, 100, 0.4), transparent 70%),
      #14121a;
  }
  .hpp__media img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 6% 6% 4%;
  }
  .hpp__placeholder { width: 40%; margin: 30% auto; opacity: 0.2; }
  .hpp__soon {
    position: absolute; inset: 0;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--h-font-display, 'Bebas Neue', sans-serif);
    font-size: clamp(2rem, 5vw, 3.5rem);
    color: rgba(255, 255, 255, 0.85);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    transform: rotate(-20deg);
    pointer-events: none;
    text-shadow: 0 6px 24px rgba(0, 0, 0, 0.7);
  }

  .hpp__thumbs {
    display: flex;
    gap: 8px;
    margin-top: 12px;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .hpp__thumbs::-webkit-scrollbar { display: none; }
  .hpp__thumb {
    flex: none;
    width: 72px;
    height: 72px;
    border-radius: 10px;
    overflow: hidden;
    background: #1b1820;
    border: 2px solid transparent;
    padding: 0;
    cursor: pointer;
  }
  .hpp__thumb.is-active { border-color: #ff4e7e; }
  .hpp__thumb img { width: 100%; height: 100%; object-fit: contain; padding: 6px; }

  .hpp__title {
    font-family: var(--h-font-display, 'Bebas Neue', sans-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1.05;
    margin: 0 0 16px;
  }
  .hpp__price {
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    font-size: clamp(1.8rem, 3vw, 2.4rem);
    font-weight: 700;
    color: #ff2e4a;
    margin: 0 0 20px;
    letter-spacing: 0.01em;
  }
  .hpp__price--soon { color: rgba(255, 255, 255, 0.75); }

  .hpp__desc {
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    color: rgba(255, 255, 255, 0.78);
    font-size: 1rem;
    line-height: 1.6;
    margin: 0 0 24px;
  }
  .hpp__desc p { margin: 0 0 0.6em; }

  .hpp__option { border: 0; padding: 0; margin: 0 0 18px; }
  .hpp__option-label {
    display: block;
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    font-size: 0.8rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgba(255, 255, 255, 0.6);
    margin-bottom: 8px;
  }
  .hpp__swatches { display: flex; flex-wrap: wrap; gap: 8px; }
  .hpp__swatch {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 8px 16px;
    border: 1px solid rgba(255, 255, 255, 0.18);
    border-radius: 999px;
    cursor: pointer;
    color: rgba(255, 255, 255, 0.85);
    font-size: 0.85rem;
    transition: border-color 0.2s ease, background 0.2s ease;
  }
  .hpp__swatch.is-active {
    border-color: #ff4e7e;
    background: rgba(255, 78, 126, 0.12);
    color: #fff;
  }

  .hpp__widgets {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin: 4px 0 16px;
  }
  .hpp__widget {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    border-radius: 14px;
    text-decoration: none;
    color: #fff;
    transition: transform 0.2s ease, filter 0.2s ease;
    min-height: 64px;
  }
  .hpp__widget:hover { transform: translateY(-1px); filter: brightness(1.08); }
  .hpp__widget--call {
    background: linear-gradient(135deg, #ff4e7e 0%, #8a5bff 100%);
  }
  .hpp__widget--wa {
    background: #25D366;
  }
  .hpp__widget-icon {
    width: 40px;
    height: 40px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.18);
    flex: none;
  }
  .hpp__widget-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
    min-width: 0;
  }
  .hpp__widget-title {
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .hpp__widget-sub {
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    font-size: 0.78rem;
    opacity: 0.85;
    letter-spacing: 0.02em;
  }
  @media screen and (max-width: 480px) {
    .hpp__widgets { grid-template-columns: 1fr; }
  }

  .hpp__empty-hint {
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.55);
    padding: 12px 16px;
    border: 1px dashed rgba(255, 255, 255, 0.18);
    border-radius: 12px;
    margin: 0 0 16px;
  }

  .hpp__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 48px;
    padding: 10px 28px;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    text-decoration: none;
    color: #fff;
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    background: linear-gradient(90deg, #ff4e7e 0%, #e84a7a 35%, #8a5bff 100%);
    transition: transform 0.2s ease, filter 0.2s ease, opacity 0.2s ease;
  }
  .hpp__cta:hover { transform: translateY(-1px); filter: brightness(1.07); }

  .hpp__meta {
    margin-top: 24px;
    padding-top: 18px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    font-size: 0.85rem;
    color: rgba(255, 255, 255, 0.65);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .hpp__meta strong { color: rgba(255, 255, 255, 0.9); font-weight: 500; }
</style>

<script>
  (function () {
    document.querySelectorAll('.hpp').forEach(function (root) {
      // Thumbnail swap
      var main = root.querySelector('[data-main] img');
      root.querySelectorAll('[data-thumb]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var src = btn.getAttribute('data-src');
          if (main && src) main.src = src;
          root.querySelectorAll('[data-thumb]').forEach(function (b) { b.classList.remove('is-active'); });
          btn.classList.add('is-active');
        });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "HOOSH Product Page",
  "class": "hoosh-section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_breadcrumbs",
      "label": "Show breadcrumbs",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_meta",
      "label": "Show product meta (type, vendor)",
      "default": false
    },
    {
      "type": "header",
      "content": "Order widgets"
    },
    {
      "type": "paragraph",
      "content": "Leave a field blank to hide the matching button. Global values from Theme settings → HOOSH Contact are used as fallback."
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone number (tel:)",
      "info": "International format, e.g. +359886969757"
    },
    {
      "type": "text",
      "id": "phone_display",
      "label": "Phone number (display)",
      "info": "How the number is shown, e.g. +359 88 696 9757"
    },
    {
      "type": "text",
      "id": "call_label",
      "label": "Call button label",
      "default": "Обади се"
    },
    {
      "type": "text",
      "id": "whatsapp",
      "label": "WhatsApp number",
      "info": "International format, digits only, e.g. 359886969757"
    },
    {
      "type": "text",
      "id": "wa_label",
      "label": "WhatsApp button label",
      "default": "Поръчай през уатсапп"
    }
  ],
  "presets": [{ "name": "HOOSH Product Page" }],
  "enabled_on": {
    "templates": ["product"]
  }
}
{% endschema %}
