{{ 'hoosh-main.css' | asset_url | stylesheet_tag }}

{%- liquid
  assign s = section.settings
  assign label_v = s.label | default: '' | strip
  assign sub_v = s.subheading | default: '' | strip
  assign head_v = s.heading | default: '' | strip

  assign has_label = false
  assign has_sub = false
  assign has_head = false
  if label_v != '' and label_v != blank
    assign has_label = true
  endif
  if sub_v != '' and sub_v != blank
    assign has_sub = true
  endif
  if head_v != '' and head_v != blank
    assign has_head = true
  endif
  assign has_header = false
  if has_label or has_sub or has_head
    assign has_header = true
  endif
  if s.hide_header
    assign has_header = false
  endif

  assign cols_desktop = s.per_row_desktop | default: 3
  assign cols_mobile = 2
  assign uid = section.id

  assign bg_color = s.bg_color | default: 'rgba(0,0,0,0)'
  assign heading_color = s.heading_color | default: '#ffffff'
  assign sub_color = s.sub_color | default: 'rgba(255,255,255,0.55)'
  assign label_bg = s.label_bg | default: 'rgba(255,255,255,0.06)'
  assign label_text = s.label_text | default: 'rgba(255,255,255,0.85)'
  assign arrow_bg = s.arrow_bg | default: '#ffffff'
  assign arrow_icon = s.arrow_icon | default: '#111111'
  assign arrow_hover_bg = s.arrow_hover_bg | default: '#00e38a'
  assign arrow_hover_icon = s.arrow_hover_icon | default: '#000000'
-%}

<section
  id="hps-{{ uid }}"
  class="hps{% unless has_header %} hps--no-header{% endunless %}"
  style="
    --hps-cols-d: {{ cols_desktop }};
    --hps-cols-m: {{ cols_mobile }};
    --hps-bg: {{ bg_color }};
    --hps-heading: {{ heading_color }};
    --hps-sub: {{ sub_color }};
    --hps-label-bg: {{ label_bg }};
    --hps-label-text: {{ label_text }};
    --hps-arrow-bg: {{ arrow_bg }};
    --hps-arrow-icon: {{ arrow_icon }};
    --hps-arrow-hover-bg: {{ arrow_hover_bg }};
    --hps-arrow-hover-icon: {{ arrow_hover_icon }};
  "
  data-hoosh
>
  <div class="h-container">
    {%- if has_header -%}
      <div class="hps__head h-reveal">
        {%- if has_label -%}<span class="hps__label">{{ label_v }}</span>{%- endif -%}
        {%- if has_sub -%}<span class="hps__sub">{{ sub_v }}</span>{%- endif -%}
        {%- if has_head -%}<h2 class="hps__title h-display">{{ head_v }}</h2>{%- endif -%}
      </div>
    {%- endif -%}

    <div class="hps__frame" data-hps-root data-cols-d="{{ cols_desktop }}" data-cols-m="{{ cols_mobile }}">
      <button type="button" class="hps__nav hps__nav--prev" data-hps-dir="-1" aria-label="Previous">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>

      <div class="hps__viewport">
        <ul class="hps__rail" data-hps-rail>
          {%- if s.collection != blank and s.collection.products.size > 0 -%}
            {%- for product in s.collection.products limit: s.max_products -%}
              <li class="hps__item">
                {% render 'hoosh-product-card', product: product %}
              </li>
            {%- endfor -%}
          {%- else -%}
            {%- for i in (1..6) -%}
              <li class="hps__item">
                {% render 'hoosh-product-card' %}
              </li>
            {%- endfor -%}
          {%- endif -%}
        </ul>
      </div>

      <button type="button" class="hps__nav hps__nav--next" data-hps-dir="1" aria-label="Next">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
  </div>
</section>

<style>
  #hps-{{ uid }}.hps {
    --hps-gap-d: 1.25rem;
    --hps-gap-m: 0.75rem;
    background: var(--hps-bg);
    padding-block-start: clamp(3rem, 7vw, 6rem);
    padding-block-end: clamp(3rem, 7vw, 6rem);
  }
  #hps-{{ uid }} .h-container {
    max-width: min(1440px, 94vw);
  }
  @media screen and (max-width: 767px) {
    #hps-{{ uid }} .h-container {
      max-width: 100%;
    }
  }
  #hps-{{ uid }}.hps--no-header {
    padding-block-start: clamp(0.75rem, 2vw, 1.5rem);
    padding-block-end: clamp(0.75rem, 2vw, 1.5rem);
  }

  #hps-{{ uid }} .hps__head {
    text-align: center;
    margin-bottom: clamp(2rem, 5vw, 4rem);
  }
  #hps-{{ uid }} .hps__label {
    display: inline-block;
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    background: var(--hps-label-bg);
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 999px;
    padding: 6px 16px;
    color: var(--hps-label-text);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    margin: 0 0 1.5em;
  }
  #hps-{{ uid }} .hps__sub {
    display: block;
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    font-size: 0.75rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--hps-sub);
    margin: 0 0 1em;
  }
  #hps-{{ uid }} .hps__title {
    font-size: var(--h-section-title);
    color: var(--hps-heading);
    margin: 0;
  }

  #hps-{{ uid }} .hps__frame {
    position: relative;
  }
  #hps-{{ uid }} .hps__viewport {
    width: 100%;
    overflow: hidden;
  }
  #hps-{{ uid }} .hps__rail {
    display: flex;
    align-items: stretch;
    gap: var(--hps-gap-d);
    margin: 0;
    padding: 4px 0;
    list-style: none;
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    scrollbar-width: none;
  }
  #hps-{{ uid }} .hps__rail::-webkit-scrollbar { display: none; }
  #hps-{{ uid }} .hps__item {
    flex: 0 0 calc((100% - (var(--hps-cols-d, 3) - 1) * var(--hps-gap-d)) / var(--hps-cols-d, 3));
    scroll-snap-align: start;
    min-width: 0;
    display: flex;
  }
  #hps-{{ uid }} .hps__item > .hp-card {
    width: 100%;
    height: 100%;
  }

  #hps-{{ uid }} .hps__nav {
    position: absolute;
    top: 38%;
    transform: translateY(-50%);
    width: 52px;
    height: 52px;
    border-radius: 50%;
    background: var(--hps-arrow-bg);
    color: var(--hps-arrow-icon);
    border: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.45);
    transition: background 0.2s ease, color 0.2s ease, transform 0.2s ease;
    z-index: 3;
  }
  #hps-{{ uid }} .hps__nav--prev { left: -10px; }
  #hps-{{ uid }} .hps__nav--next { right: -10px; }
  #hps-{{ uid }} .hps__nav:hover {
    background: var(--hps-arrow-hover-bg);
    color: var(--hps-arrow-hover-icon);
    transform: translateY(-50%) scale(1.08);
  }
  #hps-{{ uid }} .hps__nav:focus-visible {
    outline: 2px solid var(--hps-arrow-hover-bg);
    outline-offset: 3px;
  }

  @media screen and (max-width: 767px) {
    #hps-{{ uid }} .hps__nav {
      width: 40px;
      height: 40px;
      box-shadow: 0 4px 14px rgba(0, 0, 0, 0.5);
    }
    #hps-{{ uid }} .hps__nav--prev { left: 4px; }
    #hps-{{ uid }} .hps__nav--next { right: 4px; }
    #hps-{{ uid }} .hps__nav svg { width: 20px; height: 20px; }
    #hps-{{ uid }} .hps__rail {
      gap: var(--hps-gap-m);
      padding: 0;
      overflow-y: hidden;
    }
    #hps-{{ uid }} .hps__item {
      flex: 0 0 calc((100% - (var(--hps-cols-m, 2) - 1) * var(--hps-gap-m)) / var(--hps-cols-m, 2));
    }
  }
</style>

<script>
  (function () {
    var roots = document.querySelectorAll('[data-hps-root]');
    roots.forEach(function (root) {
      var rail = root.querySelector('[data-hps-rail]');
      if (!rail) return;
      var colsD = parseInt(root.getAttribute('data-cols-d'), 10) || 3;
      var colsM = parseInt(root.getAttribute('data-cols-m'), 10) || 2;

      function visibleCount() {
        return window.matchMedia('(max-width: 767px)').matches ? colsM : colsD;
      }

      function pageWidth() {
        var item = rail.querySelector('.hps__item');
        if (!item) return rail.clientWidth;
        var cs = getComputedStyle(rail);
        var gap = parseFloat(cs.columnGap || cs.gap || 0) || 0;
        var w = item.getBoundingClientRect().width;
        return (w + gap) * visibleCount();
      }

      root.querySelectorAll('[data-hps-dir]').forEach(function (btn) {
        btn.addEventListener('click', function () {
          var dir = parseInt(btn.getAttribute('data-hps-dir'), 10) || 1;
          rail.scrollBy({ left: dir * pageWidth(), behavior: 'smooth' });
        });
      });
    });
  })();
</script>

{% schema %}
{
  "name": "HOOSH Product Slider",
  "tag": "section",
  "class": "hoosh-section",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "checkbox",
      "id": "hide_header",
      "label": "Hide header",
      "default": false
    },
    {
      "type": "text",
      "id": "label",
      "label": "Category label"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Small caption (above heading)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "header",
      "content": "Products"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Max products in slider",
      "min": 2,
      "max": 24,
      "step": 1,
      "default": 12
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "per_row_desktop",
      "label": "Products per row (desktop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 3,
      "info": "Smaller number = bigger cards. Mobile is fixed at 2 per row and advances 2 at a time."
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "sub_color",
      "label": "Small caption color",
      "default": "#8a8a8a"
    },
    {
      "type": "color",
      "id": "label_bg",
      "label": "Category label background",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "label_text",
      "label": "Category label text",
      "default": "#00e38a"
    },
    {
      "type": "color",
      "id": "arrow_bg",
      "label": "Arrow button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "arrow_icon",
      "label": "Arrow icon color",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "arrow_hover_bg",
      "label": "Arrow hover background",
      "default": "#00e38a"
    },
    {
      "type": "color",
      "id": "arrow_hover_icon",
      "label": "Arrow hover icon color",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "HOOSH Product Slider",
      "settings": {
        "max_products": 12,
        "per_row_desktop": 3
      }
    }
  ]
}
{% endschema %}
