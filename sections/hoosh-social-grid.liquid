{{ 'hoosh-main.css' | asset_url | stylesheet_tag }}

<section class="hsg h-section" data-hoosh>
  <div class="hsg__header h-reveal">
    <span class="h-label">{{ section.settings.label | default: 'Join the Community' }}</span>
    <h2 class="h-display" style="font-size: var(--h-section-title);">{{ section.settings.heading | default: 'Follow Us' }}</h2>
    {%- if section.settings.handle != blank -%}
      <a href="{{ section.settings.profile_url }}" target="_blank" rel="noopener" class="hsg__handle">@{{ section.settings.handle }}</a>
    {%- endif -%}
  </div>

  <div class="hsg__grid">
    {%- for block in section.blocks -%}
      <a
        class="hsg__item h-reveal"
        href="{{ section.settings.profile_url | default: '#' }}"
        target="_blank"
        rel="noopener"
        {{ block.shopify_attributes }}
      >
        {%- if block.settings.image != blank -%}
          <img
            src="{{ block.settings.image | image_url: width: 600 }}"
            srcset="{{ block.settings.image | image_url: width: 400 }} 400w, {{ block.settings.image | image_url: width: 600 }} 600w"
            sizes="(min-width: 1024px) 20vw, (min-width: 768px) 33vw, 50vw"
            alt="{{ block.settings.alt | default: 'HOOSH on Instagram' | escape }}"
            loading="lazy"
          >
        {%- else -%}
          <div class="hsg__placeholder">{{ 'lifestyle-1' | placeholder_svg_tag }}</div>
        {%- endif -%}
        <div class="hsg__hover">
          <svg width="28" height="28" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </div>
      </a>
    {%- endfor -%}
  </div>
</section>

<style>
  .hsg__header {
    text-align: center;
    padding: 0 var(--h-section-px);
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .hsg__handle {
    font-family: var(--h-font-body);
    font-size: 1.1rem;
    color: var(--h-pink, #FF1493);
    text-decoration: none;
    display: inline-block;
    margin-top: 8px;
    transition: opacity 0.2s;
  }
  .hsg__handle:hover { opacity: 0.7; }

  /* Edge-to-edge photo grid */
  .hsg__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 4px;
  }
  .hsg__item {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    display: block;
  }
  .hsg__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s var(--h-ease, ease);
  }
  .hsg__item:hover img {
    transform: scale(1.08);
  }
  .hsg__placeholder {
    width: 100%;
    height: 100%;
    background: var(--h-bg-card, #111);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.1;
  }
  .hsg__hover {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    opacity: 0;
    transition: opacity 0.3s;
  }
  .hsg__item:hover .hsg__hover {
    opacity: 1;
  }

  @media screen and (max-width: 1023px) {
    .hsg__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  @media screen and (max-width: 767px) {
    .hsg__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }
  @media screen and (max-width: 480px) {
    .hsg__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

{% schema %}
{
  "name": "HOOSH Social Grid",
  "class": "hoosh-section",
  "settings": [
    {
      "type": "text",
      "id": "label",
      "label": "Label",
      "default": "Join the Community"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Follow Us"
    },
    {
      "type": "text",
      "id": "handle",
      "label": "Instagram handle (without @)",
      "default": "hoosh_bg"
    },
    {
      "type": "url",
      "id": "profile_url",
      "label": "Profile URL"
    }
  ],
  "blocks": [
    {
      "type": "photo",
      "name": "Photo",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo"
        },
        {
          "type": "text",
          "id": "alt",
          "label": "Alt text"
        }
      ]
    }
  ],
  "presets": [{
    "name": "HOOSH Social Grid",
    "blocks": [
      { "type": "photo" },
      { "type": "photo" },
      { "type": "photo" },
      { "type": "photo" },
      { "type": "photo" },
      { "type": "photo" },
      { "type": "photo" },
      { "type": "photo" },
      { "type": "photo" },
      { "type": "photo" }
    ]
  }]
}
{% endschema %}
