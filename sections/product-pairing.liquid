{% comment %}
  HOOSH — Product Pairing Section (v4)
  Compact viewport, horizontal nav for package, auto-ratio single image.
{% endcomment %}

{% liquid
  assign singles = section.settings.singles_collection
  assign packages = section.settings.packages_collection
  assign product_count = 0

  if singles != blank and packages != blank
    if singles.products.size <= packages.products.size
      assign product_count = singles.products.size
    else
      assign product_count = packages.products.size
    endif
  endif
%}

<section
  class="pp color-{{ section.settings.color_scheme }}"
  data-section-id="{{ section.id }}"
>
  {%- comment -%} ── Decorative layer ── {%- endcomment -%}
  <div class="pp__decor" aria-hidden="true">
    <svg class="pp__decor-lines" viewBox="0 0 1440 900" preserveAspectRatio="none" fill="none" xmlns="http://www.w3.org/2000/svg">
      <line x1="0" y1="180" x2="1440" y2="180" stroke="currentColor" stroke-width="0.5" opacity="0.06"/>
      <line x1="0" y1="450" x2="1440" y2="450" stroke="currentColor" stroke-width="0.5" opacity="0.06"/>
      <line x1="0" y1="720" x2="1440" y2="720" stroke="currentColor" stroke-width="0.5" opacity="0.06"/>
      <line x1="480" y1="0" x2="480" y2="900" stroke="currentColor" stroke-width="0.5" opacity="0.06"/>
      <line x1="960" y1="0" x2="960" y2="900" stroke="currentColor" stroke-width="0.5" opacity="0.06"/>
      <line x1="100" y1="0" x2="500" y2="900" stroke="currentColor" stroke-width="0.4" opacity="0.04"/>
      <line x1="900" y1="0" x2="1300" y2="900" stroke="currentColor" stroke-width="0.4" opacity="0.04"/>
    </svg>
    <div class="pp__float pp__float--1"></div>
    <div class="pp__float pp__float--2"></div>
    <div class="pp__float pp__float--3"></div>
    <div class="pp__float pp__float--4"></div>
    <div class="pp__float pp__float--5"></div>
    <div class="pp__dot-grid pp__dot-grid--left"></div>
    <div class="pp__dot-grid pp__dot-grid--right"></div>
  </div>

  <div class="pp__inner">

    {%- if product_count > 0 -%}
      <div class="pp__layout" data-pairing-container>

        {%- comment -%} ══════════════════════════════════
             LEFT — Single item (compact, auto ratio, first image only)
        ══════════════════════════════════ {%- endcomment -%}
        <div class="pp__single" aria-live="polite">
          <span class="pp__tag">{{ section.settings.single_label | default: 'Single' }}</span>

          {%- for product in singles.products limit: product_count -%}
            {%- assign single_image = product.images[0] -%}
            <div
              class="pp__single-card{% if forloop.first %} is-active{% endif %}"
              data-pairing-single="{{ forloop.index0 }}"
            >
              <a href="{{ product.url }}" class="pp__card-link">
                <div class="pp__single-img-wrap">
                  {%- if single_image != blank -%}
                    <img
                      src="{{ single_image | image_url: width: 400 }}"
                      srcset="
                        {{ single_image | image_url: width: 250 }} 250w,
                        {{ single_image | image_url: width: 400 }} 400w
                      "
                      sizes="(min-width: 750px) 18vw, 45vw"
                      alt="{{ single_image.alt | default: product.title | escape }}"
                      loading="lazy"
                      width="{{ single_image.width }}"
                      height="{{ single_image.height }}"
                      class="pp__img pp__img--single"
                    >
                  {%- else -%}
                    <div class="pp__placeholder">{{ 'product-1' | placeholder_svg_tag }}</div>
                  {%- endif -%}

                  <div class="pp__badge pp__badge--sm">
                    <span class="pp__badge-title">{{ product.title }}</span>
                    <span class="pp__badge-price">{{ product.price | money }}</span>
                  </div>
                </div>
              </a>
            </div>
          {%- endfor -%}

          <div class="pp__connector" aria-hidden="true">
            <span class="pp__connector-text">{{ section.settings.connector_text | default: 'Included in' }}</span>
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>

        {%- comment -%} ══════════════════════════════════
             RIGHT — Package with horizontal nav
        ══════════════════════════════════ {%- endcomment -%}
        <div class="pp__package">
          <div class="pp__package-header">
            <span class="pp__tag">{{ section.settings.package_label | default: 'Package of 10' }}</span>
            <div class="pp__counter" aria-label="Showing pair 1 of {{ product_count }}">
              <span data-pairing-current>01</span>
              <span class="pp__counter-sep">&mdash;</span>
              <span>{{ product_count | prepend: '00' | slice: -2, 2 }}</span>
            </div>
          </div>

          {%- comment -%} ── Horizontal nav wraps around viewport ── {%- endcomment -%}
          <div class="pp__package-row">
            <button
              class="pp__nav-h pp__nav-h--prev"
              data-pairing-nav="prev"
              aria-label="Previous package"
              {% if product_count <= 1 %}disabled{% endif %}
            >
              <svg width="10" height="16" viewBox="0 0 10 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M9 1L2 8l7 7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>

            <div class="pp__package-viewport" aria-live="polite">
              {%- for product in packages.products limit: product_count -%}
                <div
                  class="pp__package-card{% if forloop.first %} is-active{% endif %}"
                  data-pairing-package="{{ forloop.index0 }}"
                >
                  <a href="{{ product.url }}" class="pp__card-link">
                    <div class="pp__package-img-wrap">
                      {%- if product.featured_image != blank -%}
                        <img
                          src="{{ product.featured_image | image_url: width: 800 }}"
                          srcset="
                            {{ product.featured_image | image_url: width: 500 }} 500w,
                            {{ product.featured_image | image_url: width: 800 }} 800w
                          "
                          sizes="(min-width: 750px) 48vw, 90vw"
                          alt="{{ product.featured_image.alt | escape }}"
                          loading="lazy"
                          width="{{ product.featured_image.width }}"
                          height="{{ product.featured_image.height }}"
                          class="pp__img"
                        >
                      {%- else -%}
                        <div class="pp__placeholder">{{ 'product-2' | placeholder_svg_tag }}</div>
                      {%- endif -%}

                      <div class="pp__badge pp__badge--lg">
                        <span class="pp__badge-title">{{ product.title }}</span>
                        <span class="pp__badge-price">{{ product.price | money }}</span>
                      </div>
                    </div>
                  </a>
                </div>
              {%- endfor -%}
            </div>

            <button
              class="pp__nav-h pp__nav-h--next"
              data-pairing-nav="next"
              aria-label="Next package"
              {% if product_count <= 1 %}disabled{% endif %}
            >
              <svg width="10" height="16" viewBox="0 0 10 16" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M1 1l7 7-7 7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </div>
        </div>

      </div>

      {%- if section.settings.bottom_note != blank -%}
        <p class="pp__note">{{ section.settings.bottom_note }}</p>
      {%- endif -%}

    {%- else -%}
      <div class="pp__empty">
        <p>Select a <strong>Singles</strong> collection and a <strong>Packages</strong> collection in the section settings.</p>
        <p class="pp__empty-hint">Products are paired by position — 1st single ↔ 1st package, 2nd ↔ 2nd, and so on.</p>
      </div>
    {%- endif -%}

  </div>
</section>

<script>
  (function() {
    const section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;
    const container = section.querySelector('[data-pairing-container]');
    if (!container) return;

    const singles = container.querySelectorAll('[data-pairing-single]');
    const packages = container.querySelectorAll('[data-pairing-package]');
    const prevBtn = container.querySelector('[data-pairing-nav="prev"]');
    const nextBtn = container.querySelector('[data-pairing-nav="next"]');
    const counterEl = container.querySelector('[data-pairing-current]');
    const total = Math.min(singles.length, packages.length);
    let current = 0;

    function pad(n) { return String(n).padStart(2, '0'); }

    function goTo(index) {
      if (index < 0 || index >= total) return;
      const oldS = container.querySelector('[data-pairing-single].is-active');
      const oldP = container.querySelector('[data-pairing-package].is-active');
      if (oldS) oldS.classList.remove('is-active');
      if (oldP) oldP.classList.remove('is-active');

      current = index;
      singles[current].classList.add('is-active');
      packages[current].classList.add('is-active');

      if (counterEl) counterEl.textContent = pad(current + 1);
      if (prevBtn) prevBtn.disabled = current === 0;
      if (nextBtn) nextBtn.disabled = current === total - 1;
    }

    if (prevBtn) prevBtn.addEventListener('click', function() { goTo(current - 1); });
    if (nextBtn) nextBtn.addEventListener('click', function() { goTo(current + 1); });

    container.addEventListener('keydown', function(e) {
      if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') { e.preventDefault(); goTo(current - 1); }
      if (e.key === 'ArrowDown' || e.key === 'ArrowRight') { e.preventDefault(); goTo(current + 1); }
    });
  })();
</script>

{% stylesheet %}
  /* ═══════════════════════════════════════
     Product Pairing v4
  ═══════════════════════════════════════ */
  .pp {
    position: relative;
    height: 100vh;
    height: 100dvh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .pp__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 var(--padding-lg);
  }

  /* ═══════════════════════════════════════
     Decorative
  ═══════════════════════════════════════ */
  .pp__decor {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .pp__decor-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    color: var(--color-foreground);
  }

  .pp__float {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.06);
  }

  .pp__float--1 { width: 320px; height: 320px; top: -80px; right: -60px; animation: ppFloat 18s ease-in-out infinite; }
  .pp__float--2 { width: 180px; height: 180px; bottom: 60px; left: -40px; border-style: dashed; animation: ppFloat 14s ease-in-out infinite reverse; }
  .pp__float--3 { width: 80px; height: 80px; top: 30%; left: 38%; background: rgb(var(--color-foreground-rgb) / 0.02); animation: ppFloat 10s ease-in-out infinite 2s; }
  .pp__float--4 { width: 12px; height: 12px; top: 20%; right: 20%; background: rgb(var(--color-foreground-rgb) / 0.08); animation: ppFloat 8s ease-in-out infinite 1s; }
  .pp__float--5 { width: 6px; height: 6px; bottom: 25%; left: 30%; background: rgb(var(--color-foreground-rgb) / 0.1); animation: ppFloat 12s ease-in-out infinite 3s; }

  .pp__dot-grid {
    position: absolute;
    width: 120px; height: 120px;
    background-image: radial-gradient(circle, rgb(var(--color-foreground-rgb) / 0.07) 1px, transparent 1px);
    background-size: 16px 16px;
  }

  .pp__dot-grid--left { bottom: 80px; left: 40px; }
  .pp__dot-grid--right { top: 60px; right: 80px; width: 80px; height: 80px; background-size: 12px 12px; }

  @keyframes ppFloat {
    0%, 100% { transform: translate(0, 0); }
    33% { transform: translate(8px, -12px); }
    66% { transform: translate(-6px, 8px); }
  }

  /* ═══════════════════════════════════════
     Layout
  ═══════════════════════════════════════ */
  .pp__layout {
    display: grid;
    grid-template-columns: 0.4fr 1.6fr;
    gap: clamp(20px, 3vw, 44px);
    align-items: center;
  }

  .pp__tag {
    display: inline-block;
    font-family: var(--font-body--family);
    font-weight: 500;
    font-size: 0.58rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-foreground);
    opacity: 0.4;
    margin-bottom: 8px;
  }

  /* ═══════════════════════════════════════
     Badges
  ═══════════════════════════════════════ */
  .pp__badge {
    position: absolute;
    top: 10px;
    right: 10px;
    background: var(--color-background);
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.08);
    display: flex;
    flex-direction: column;
    gap: 2px;
    z-index: 2;
  }

  /* Small badge — single item */
  .pp__badge--sm {
    padding: 6px 10px;
    max-width: 70%;
  }

  .pp__badge--sm .pp__badge-title {
    font-size: 0.6rem;
  }

  .pp__badge--sm .pp__badge-price {
    font-size: 0.55rem;
  }

  /* Large badge — package */
  .pp__badge--lg {
    padding: 10px 16px;
    max-width: 55%;
  }

  .pp__badge--lg .pp__badge-title {
    font-size: 0.78rem;
    white-space: normal;
    line-height: 1.35;
  }

  .pp__badge--lg .pp__badge-price {
    font-size: 0.72rem;
    margin-top: 2px;
  }

  .pp__badge-title {
    font-family: var(--font-body--family);
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--color-foreground-heading);
    line-height: 1.3;
  }

  .pp__badge-price {
    font-family: var(--font-body--family);
    color: var(--color-foreground);
    opacity: 0.5;
  }

  /* ═══════════════════════════════════════
     Shared
  ═══════════════════════════════════════ */
  .pp__card-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .pp__img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
  }

  .pp__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.1;
    padding: 25%;
  }

  /* ═══════════════════════════════════════
     LEFT — Single (small, auto-ratio)
  ═══════════════════════════════════════ */
  .pp__single {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .pp__single-card {
    display: none;
    width: 100%;
    animation: ppFadeIn 0.3s ease;
  }

  .pp__single-card.is-active { display: block; }

  .pp__single-img-wrap {
    position: relative;
    overflow: hidden;
    background: rgb(var(--color-foreground-rgb) / 0.025);
  }

  /* Auto ratio — image dictates height */
  .pp__img--single {
    display: block;
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .pp__connector {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 12px;
    color: var(--color-foreground);
    opacity: 0.3;
  }

  .pp__connector-text {
    font-family: var(--font-body--family);
    font-size: 0.58rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  /* ═══════════════════════════════════════
     RIGHT — Package with horizontal nav
  ═══════════════════════════════════════ */
  .pp__package {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .pp__package-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 8px;
  }

  .pp__counter {
    font-family: var(--font-body--family);
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    color: var(--color-foreground);
    opacity: 0.3;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .pp__counter-sep { font-size: 0.5rem; }

  /* ── Horizontal row: prev | viewport | next ── */
  .pp__package-row {
    display: flex;
    align-items: stretch;
    gap: 0;
  }

  .pp__nav-h {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    min-width: 48px;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
    background: transparent;
    color: var(--color-foreground-heading);
    cursor: pointer;
    transition: background 0.2s ease, border-color 0.2s ease;
    flex-shrink: 0;
  }

  .pp__nav-h:hover:not(:disabled) {
    background: rgb(var(--color-foreground-rgb) / 0.04);
    border-color: rgb(var(--color-foreground-rgb) / 0.25);
  }

  .pp__nav-h:disabled { opacity: 0.15; cursor: not-allowed; }

  .pp__nav-h--prev {
    border-right: none;
  }

  .pp__nav-h--next {
    border-left: none;
  }

  .pp__package-viewport {
    position: relative;
    flex: 1;
    min-width: 0;
  }

  .pp__package-card {
    display: none;
    animation: ppFadeIn 0.3s ease;
  }

  .pp__package-card.is-active { display: block; }

  .pp__package-img-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: rgb(var(--color-foreground-rgb) / 0.025);
  }

  /* ── Bottom note ── */
  .pp__note {
    position: relative;
    z-index: 2;
    text-align: center;
    margin-top: 20px;
    font-family: var(--font-body--family);
    font-size: 0.65rem;
    color: var(--color-foreground);
    opacity: 0.3;
    line-height: 1.55;
    max-width: 420px;
    margin-inline: auto;
  }

  /* ── Empty state ── */
  .pp__empty {
    text-align: center;
    padding: 80px 20px;
    border: 1px dashed var(--color-border);
    border-radius: 8px;
  }

  .pp__empty p {
    font-family: var(--font-body--family);
    font-size: 0.9rem;
    color: var(--color-foreground);
    margin: 0 0 8px;
    line-height: 1.6;
  }

  .pp__empty-hint { opacity: 0.5; font-size: 0.82rem !important; }

  @keyframes ppFadeIn {
    from { opacity: 0; transform: translateY(6px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* ═══════════════════════════════════════
     MOBILE — keep same as before
  ═══════════════════════════════════════ */
  @media screen and (max-width: 749px) {
    .pp {
      height: 100vh;
      height: 100dvh;
      align-items: stretch;
    }

    .pp__inner {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 24px var(--padding-lg);
    }

    .pp__layout {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .pp__package { order: 1; }
    .pp__single { order: 2; }

    .pp__single-card.is-active {
      display: flex;
      align-items: center;
    }

    .pp__card-link {
      display: flex;
      align-items: center;
      gap: 14px;
      width: 100%;
    }

    .pp__single-img-wrap {
      width: 80px;
      min-width: 80px;
    }

    .pp__img--single {
      width: 100%;
      height: auto;
    }

    .pp__badge {
      position: static;
      background: none;
      border: none;
      padding: 0;
      max-width: none;
    }

    .pp__badge--sm .pp__badge-title,
    .pp__badge--lg .pp__badge-title { font-size: 0.72rem; }

    .pp__badge--sm .pp__badge-price,
    .pp__badge--lg .pp__badge-price { font-size: 0.65rem; }

    .pp__connector { display: none; }

    /* Mobile: vertical nav buttons instead of horizontal */
    .pp__package-row {
      flex-direction: column;
    }

    .pp__nav-h {
      width: 100%;
      min-width: auto;
      height: 40px;
      padding: 10px;
    }

    .pp__nav-h--prev {
      border-right: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
      border-bottom: none;
    }

    .pp__nav-h--next {
      border-left: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
      border-top: none;
    }

    .pp__nav-h--prev svg { transform: rotate(90deg); }
    .pp__nav-h--next svg { transform: rotate(90deg); }

    .pp__package-img-wrap { aspect-ratio: 3 / 4; }

    .pp__float--1 { width: 160px; height: 160px; }
    .pp__float--2 { width: 100px; height: 100px; }
    .pp__dot-grid--right { display: none; }
    .pp__dot-grid--left { width: 60px; height: 60px; }

    .pp__note { margin-top: 16px; font-size: 0.62rem; }
  }

  @media screen and (max-width: 399px) {
    .pp__single-img-wrap { width: 64px; min-width: 64px; }
    .pp__nav-h { height: 36px; padding: 8px; }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Product Pairing",
  "class": "product-pairing-section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Collections"
    },
    {
      "type": "collection",
      "id": "singles_collection",
      "label": "Singles collection",
      "info": "The individual items (e.g. single flavours)"
    },
    {
      "type": "collection",
      "id": "packages_collection",
      "label": "Packages collection",
      "info": "The bundled packs (e.g. pack of 10). Products are paired by position — 1st single ↔ 1st package."
    },
    {
      "type": "header",
      "content": "Labels & text"
    },
    {
      "type": "text",
      "id": "single_label",
      "label": "Single item label",
      "default": "Single"
    },
    {
      "type": "text",
      "id": "package_label",
      "label": "Package label",
      "default": "Package of 10"
    },
    {
      "type": "text",
      "id": "connector_text",
      "label": "Connector text",
      "default": "Included in",
      "info": "Shown between the single and the package on desktop."
    },
    {
      "type": "text",
      "id": "prev_text",
      "label": "Previous button text",
      "default": "Previous"
    },
    {
      "type": "text",
      "id": "next_text",
      "label": "Next button text",
      "default": "Next"
    },
    {
      "type": "text",
      "id": "bottom_note",
      "label": "Bottom note",
      "default": "Each package contains 10 individually wrapped items of the selected flavour."
    },
    {
      "type": "header",
      "content": "Style"
    },
