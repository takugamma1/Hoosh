{% comment %}
  HOOSH — Product Pairing Section (v2)
  Full-viewport, asymmetric layout: small single item + dominant package.
  Decorative floating elements for visual interest.
{% endcomment %}

{% liquid
  assign singles = section.settings.singles_collection
  assign packages = section.settings.packages_collection
  assign product_count = 0

  if singles != blank and packages != blank
    if singles.products.size <= packages.products.size
      assign product_count = singles.products.size
    else
      assign product_count = packages.products.size
    endif
  endif
%}

<section
  class="pp color-{{ section.settings.color_scheme }}"
  data-section-id="{{ section.id }}"
>
  {%- comment -%} ── Decorative layer ── {%- endcomment -%}
  <div class="pp__decor" aria-hidden="true">
    <svg class="pp__decor-lines" viewBox="0 0 1440 900" preserveAspectRatio="none" fill="none" xmlns="http://www.w3.org/2000/svg">
      <line x1="0" y1="180" x2="1440" y2="180" stroke="currentColor" stroke-width="0.5" opacity="0.06"/>
      <line x1="0" y1="450" x2="1440" y2="450" stroke="currentColor" stroke-width="0.5" opacity="0.06"/>
      <line x1="0" y1="720" x2="1440" y2="720" stroke="currentColor" stroke-width="0.5" opacity="0.06"/>
      <line x1="480" y1="0" x2="480" y2="900" stroke="currentColor" stroke-width="0.5" opacity="0.06"/>
      <line x1="960" y1="0" x2="960" y2="900" stroke="currentColor" stroke-width="0.5" opacity="0.06"/>
      <line x1="100" y1="0" x2="500" y2="900" stroke="currentColor" stroke-width="0.4" opacity="0.04"/>
      <line x1="900" y1="0" x2="1300" y2="900" stroke="currentColor" stroke-width="0.4" opacity="0.04"/>
    </svg>
    <div class="pp__float pp__float--1"></div>
    <div class="pp__float pp__float--2"></div>
    <div class="pp__float pp__float--3"></div>
    <div class="pp__float pp__float--4"></div>
    <div class="pp__float pp__float--5"></div>
    <div class="pp__dot-grid pp__dot-grid--left"></div>
    <div class="pp__dot-grid pp__dot-grid--right"></div>
  </div>

  <div class="pp__inner">

    {%- if product_count > 0 -%}
      <div class="pp__layout" data-pairing-container>

        {%- comment -%} ══════════════════════════════════
             LEFT — Single item (compact, text overlay)
        ══════════════════════════════════ {%- endcomment -%}
        <div class="pp__single" aria-live="polite">

          {%- comment -%} ── Small label ── {%- endcomment -%}
          <span class="pp__tag">{{ section.settings.single_label | default: 'Single' }}</span>

          {%- for product in singles.products limit: product_count -%}
            <div
              class="pp__single-card{% if forloop.first %} is-active{% endif %}"
              data-pairing-single="{{ forloop.index0 }}"
            >
              <a href="{{ product.url }}" class="pp__single-link">
                <div class="pp__single-img-wrap">
                  {%- if product.featured_image != blank -%}
                    <img
                      src="{{ product.featured_image | image_url: width: 500 }}"
                      srcset="
                        {{ product.featured_image | image_url: width: 300 }} 300w,
                        {{ product.featured_image | image_url: width: 500 }} 500w
                      "
                      sizes="(min-width: 750px) 28vw, 45vw"
                      alt="{{ product.featured_image.alt | escape }}"
                      loading="lazy"
                      width="{{ product.featured_image.width }}"
                      height="{{ product.featured_image.height }}"
                      class="pp__img"
                    >
                  {%- else -%}
                    <div class="pp__placeholder">{{ 'product-1' | placeholder_svg_tag }}</div>
                  {%- endif -%}

                  {%- comment -%} ── Text overlay on the image ── {%- endcomment -%}
                  <div class="pp__single-overlay">
                    <span class="pp__single-overlay-label">{{ section.settings.overlay_text | default: 'Also available as' }}</span>
                    <h3 class="pp__single-overlay-title">{{ product.title }}</h3>
                    <span class="pp__single-overlay-price">{{ product.price | money }}</span>
                  </div>
                </div>
              </a>
            </div>
          {%- endfor -%}

          {%- comment -%} ── Connector arrow ── {%- endcomment -%}
          <div class="pp__connector" aria-hidden="true">
            <span class="pp__connector-text">{{ section.settings.connector_text | default: 'Included in' }}</span>
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M5 12h14M13 6l6 6-6 6" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
        </div>

        {%- comment -%} ══════════════════════════════════
             RIGHT — Package (dominant, large)
        ══════════════════════════════════ {%- endcomment -%}
        <div class="pp__package">

          {%- comment -%} ── Package header with label + counter ── {%- endcomment -%}
          <div class="pp__package-header">
            <span class="pp__tag">{{ section.settings.package_label | default: 'Package of 10' }}</span>
            <div class="pp__counter" aria-label="Showing pair 1 of {{ product_count }}">
              <span data-pairing-current>01</span>
              <span class="pp__counter-sep">&mdash;</span>
              <span>{{ product_count | prepend: '00' | slice: -2, 2 }}</span>
            </div>
          </div>

          {%- comment -%} ── Nav: Previous ── {%- endcomment -%}
          <button
            class="pp__nav pp__nav--prev"
            data-pairing-nav="prev"
            aria-label="Previous package"
            {% if product_count <= 1 %}disabled{% endif %}
          >
            <svg width="16" height="10" viewBox="0 0 16 10" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M1 9L8 2l7 7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            <span>{{ section.settings.prev_text | default: 'Previous' }}</span>
          </button>

          {%- comment -%} ── Package product viewport ── {%- endcomment -%}
          <div class="pp__package-viewport" aria-live="polite">
            {%- for product in packages.products limit: product_count -%}
              <div
                class="pp__package-card{% if forloop.first %} is-active{% endif %}"
                data-pairing-package="{{ forloop.index0 }}"
              >
                <a href="{{ product.url }}" class="pp__package-link">
                  <div class="pp__package-img-wrap">
                    {%- if product.featured_image != blank -%}
                      <img
                        src="{{ product.featured_image | image_url: width: 900 }}"
                        srcset="
                          {{ product.featured_image | image_url: width: 500 }} 500w,
                          {{ product.featured_image | image_url: width: 700 }} 700w,
                          {{ product.featured_image | image_url: width: 900 }} 900w
                        "
                        sizes="(min-width: 750px) 55vw, 90vw"
                        alt="{{ product.featured_image.alt | escape }}"
                        loading="lazy"
                        width="{{ product.featured_image.width }}"
                        height="{{ product.featured_image.height }}"
                        class="pp__img pp__img--package"
                      >
                    {%- else -%}
                      <div class="pp__placeholder">{{ 'product-2' | placeholder_svg_tag }}</div>
                    {%- endif -%}
                  </div>
                  <div class="pp__package-info">
                    <h3 class="pp__package-title">{{ product.title }}</h3>
                    <span class="pp__package-price">{{ product.price | money }}</span>
                  </div>
                </a>
              </div>
            {%- endfor -%}
          </div>

          {%- comment -%} ── Nav: Next ── {%- endcomment -%}
          <button
            class="pp__nav pp__nav--next"
            data-pairing-nav="next"
            aria-label="Next package"
            {% if product_count <= 1 %}disabled{% endif %}
          >
            <span>{{ section.settings.next_text | default: 'Next' }}</span>
            <svg width="16" height="10" viewBox="0 0 16 10" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M1 1l7 7 7-7" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
        </div>

      </div>

      {%- comment -%} ── Bottom note ── {%- endcomment -%}
      {%- if section.settings.bottom_note != blank -%}
        <p class="pp__note">{{ section.settings.bottom_note }}</p>
      {%- endif -%}

    {%- else -%}
      <div class="pp__empty">
        <p>Select a <strong>Singles</strong> collection and a <strong>Packages</strong> collection in the section settings.</p>
        <p class="pp__empty-hint">Products are paired by position — 1st single ↔ 1st package, 2nd ↔ 2nd, and so on.</p>
      </div>
    {%- endif -%}

  </div>
</section>

<script>
  (function() {
    const section = document.querySelector('[data-section-id="{{ section.id }}"]');
    if (!section) return;
    const container = section.querySelector('[data-pairing-container]');
    if (!container) return;

    const singles = container.querySelectorAll('[data-pairing-single]');
    const packages = container.querySelectorAll('[data-pairing-package]');
    const prevBtn = container.querySelector('[data-pairing-nav="prev"]');
    const nextBtn = container.querySelector('[data-pairing-nav="next"]');
    const counterEl = container.querySelector('[data-pairing-current]');
    const total = Math.min(singles.length, packages.length);
    let current = 0;

    function pad(n) { return String(n).padStart(2, '0'); }

    function goTo(index) {
      if (index < 0 || index >= total) return;
      const oldS = container.querySelector('[data-pairing-single].is-active');
      const oldP = container.querySelector('[data-pairing-package].is-active');
      if (oldS) { oldS.classList.remove('is-active'); oldS.classList.add('is-leaving'); }
      if (oldP) { oldP.classList.remove('is-active'); oldP.classList.add('is-leaving'); }

      current = index;

      requestAnimationFrame(function() {
        if (oldS) oldS.classList.remove('is-leaving');
        if (oldP) oldP.classList.remove('is-leaving');
        singles[current].classList.add('is-active');
        packages[current].classList.add('is-active');
      });

      if (counterEl) counterEl.textContent = pad(current + 1);
      if (prevBtn) prevBtn.disabled = current === 0;
      if (nextBtn) nextBtn.disabled = current === total - 1;
    }

    if (prevBtn) prevBtn.addEventListener('click', function() { goTo(current - 1); });
    if (nextBtn) nextBtn.addEventListener('click', function() { goTo(current + 1); });

    container.addEventListener('keydown', function(e) {
      if (e.key === 'ArrowUp' || e.key === 'ArrowLeft') { e.preventDefault(); goTo(current - 1); }
      if (e.key === 'ArrowDown' || e.key === 'ArrowRight') { e.preventDefault(); goTo(current + 1); }
    });
  })();
</script>

{% stylesheet %}
  /* ═══════════════════════════════════════
     Product Pairing v2 — Full-viewport
  ═══════════════════════════════════════ */
  .pp {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .pp__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 40px var(--padding-lg);
  }

  /* ═══════════════════════════════════════
     Decorative Elements
  ═══════════════════════════════════════ */
  .pp__decor {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .pp__decor-lines {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    color: var(--color-foreground);
  }

  /* ── Floating circles ── */
  .pp__float {
    position: absolute;
    border-radius: 50%;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.06);
  }

  .pp__float--1 {
    width: 320px;
    height: 320px;
    top: -80px;
    right: -60px;
    animation: ppFloat 18s ease-in-out infinite;
  }

  .pp__float--2 {
    width: 180px;
    height: 180px;
    bottom: 60px;
    left: -40px;
    border-style: dashed;
    animation: ppFloat 14s ease-in-out infinite reverse;
  }

  .pp__float--3 {
    width: 80px;
    height: 80px;
    top: 30%;
    left: 38%;
    background: rgb(var(--color-foreground-rgb) / 0.02);
    animation: ppFloat 10s ease-in-out infinite 2s;
  }

  .pp__float--4 {
    width: 12px;
    height: 12px;
    top: 20%;
    right: 20%;
    background: rgb(var(--color-foreground-rgb) / 0.08);
    animation: ppFloat 8s ease-in-out infinite 1s;
  }

  .pp__float--5 {
    width: 6px;
    height: 6px;
    bottom: 25%;
    left: 30%;
    background: rgb(var(--color-foreground-rgb) / 0.1);
    animation: ppFloat 12s ease-in-out infinite 3s;
  }

  /* ── Dot grids ── */
  .pp__dot-grid {
    position: absolute;
    width: 120px;
    height: 120px;
    background-image: radial-gradient(circle, rgb(var(--color-foreground-rgb) / 0.07) 1px, transparent 1px);
    background-size: 16px 16px;
  }

  .pp__dot-grid--left {
    bottom: 80px;
    left: 40px;
  }

  .pp__dot-grid--right {
    top: 60px;
    right: 80px;
    width: 80px;
    height: 80px;
    background-size: 12px 12px;
  }

  @keyframes ppFloat {
    0%, 100% { transform: translate(0, 0); }
    33% { transform: translate(8px, -12px); }
    66% { transform: translate(-6px, 8px); }
  }

  /* ═══════════════════════════════════════
     Layout — Asymmetric 2-col (35% / 60%)
  ═══════════════════════════════════════ */
  .pp__layout {
    display: grid;
    grid-template-columns: 1fr 1.8fr;
    gap: clamp(24px, 4vw, 56px);
    align-items: center;
    min-height: calc(100vh - 160px);
    min-height: calc(100dvh - 160px);
  }

  /* ═══════════════════════════════════════
     Tag labels
  ═══════════════════════════════════════ */
  .pp__tag {
    display: inline-block;
    font-family: var(--font-body--family);
    font-weight: 500;
    font-size: 0.62rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-foreground);
    opacity: 0.4;
    margin-bottom: 14px;
  }

  /* ═══════════════════════════════════════
     LEFT — Single item (compact, overlay text)
  ═══════════════════════════════════════ */
  .pp__single {
    position: relative;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
  }

  .pp__single-card {
    display: none;
    width: 100%;
    animation: ppSlideIn 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .pp__single-card.is-active {
    display: block;
  }

  .pp__single-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .pp__single-img-wrap {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: rgb(var(--color-foreground-rgb) / 0.03);
    border-radius: var(--product-corner-radius, 0);
  }

  .pp__single-link:hover .pp__img {
    transform: scale(1.05);
  }

  /* ── Text overlay on single image ── */
  .pp__single-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 24px 20px;
    background: linear-gradient(to top, rgb(0 0 0 / 0.55) 0%, rgb(0 0 0 / 0) 100%);
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .pp__single-overlay-label {
    font-family: var(--font-body--family);
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.55);
  }

  .pp__single-overlay-title {
    font-family: var(--font-body--family);
    font-weight: 500;
    font-size: clamp(0.85rem, 1.1vw, 1rem);
    color: #fff;
    margin: 0;
    line-height: 1.35;
    letter-spacing: 0.02em;
  }

  .pp__single-overlay-price {
    font-family: var(--font-body--family);
    font-size: 0.78rem;
    color: rgba(255, 255, 255, 0.6);
  }

  /* ── Connector (arrow between single → package) ── */
  .pp__connector {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-top: 20px;
    color: var(--color-foreground);
    opacity: 0.3;
  }

  .pp__connector-text {
    font-family: var(--font-body--family);
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    white-space: nowrap;
  }

  /* ═══════════════════════════════════════
     RIGHT — Package (dominant, large)
  ═══════════════════════════════════════ */
  .pp__package {
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .pp__package-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .pp__counter {
    font-family: var(--font-body--family);
    font-size: 0.72rem;
    letter-spacing: 0.06em;
    color: var(--color-foreground);
    opacity: 0.3;
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .pp__counter-sep {
    font-size: 0.55rem;
  }

  /* ── Nav buttons ── */
  .pp__nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 14px 24px;
    border: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
    background: transparent;
    color: var(--color-foreground-heading);
    cursor: pointer;
    font-family: var(--font-body--family);
    font-size: 0.68rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    transition: background 0.25s ease, opacity 0.25s ease, border-color 0.3s ease;
  }

  .pp__nav:hover:not(:disabled) {
    background: rgb(var(--color-foreground-rgb) / 0.04);
    border-color: rgb(var(--color-foreground-rgb) / 0.25);
  }

  .pp__nav:disabled {
    opacity: 0.15;
    cursor: not-allowed;
  }

  .pp__nav--prev {
    flex-direction: column;
    border-radius: var(--product-corner-radius, 0) var(--product-corner-radius, 0) 0 0;
    border-bottom: none;
  }

  .pp__nav--next {
    flex-direction: column;
    border-radius: 0 0 var(--product-corner-radius, 0) var(--product-corner-radius, 0);
    border-top: none;
  }

  /* ── Package viewport ── */
  .pp__package-viewport {
    position: relative;
  }

  .pp__package-card {
    display: none;
    animation: ppSlideIn 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .pp__package-card.is-active {
    display: block;
  }

  .pp__package-link {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .pp__package-img-wrap {
    position: relative;
    aspect-ratio: 4 / 3;
    overflow: hidden;
    background: rgb(var(--color-foreground-rgb) / 0.03);
    border-left: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
    border-right: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .pp__package-link:hover .pp__img--package {
    transform: scale(1.03);
  }

  .pp__package-info {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 16px 4px 0;
  }

  .pp__package-title {
    font-family: var(--font-body--family);
    font-weight: 500;
    font-size: clamp(0.85rem, 1.1vw, 1rem);
    letter-spacing: 0.03em;
    text-transform: uppercase;
    color: var(--color-foreground-heading);
    margin: 0;
    line-height: 1.4;
  }

  .pp__package-price {
    font-family: var(--font-body--family);
    font-size: 0.85rem;
    color: var(--color-foreground);
    opacity: 0.5;
    white-space: nowrap;
  }

  /* ── Shared image styles ── */
  .pp__img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
    padding: 6%;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .pp__img--package {
    padding: 4%;
  }

  .pp__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.1;
    padding: 25%;
  }

  /* ── Bottom note ── */
  .pp__note {
    position: relative;
    z-index: 2;
    text-align: center;
    margin-top: 32px;
    font-family: var(--font-body--family);
    font-size: 0.72rem;
    color: var(--color-foreground);
    opacity: 0.3;
    letter-spacing: 0.01em;
    line-height: 1.55;
    max-width: 420px;
    margin-inline: auto;
  }

  /* ── Empty state ── */
  .pp__empty {
    text-align: center;
    padding: 80px 20px;
    border: 1px dashed var(--color-border);
    border-radius: 8px;
  }

  .pp__empty p {
    font-family: var(--font-body--family);
    font-size: 0.9rem;
    color: var(--color-foreground);
    margin: 0 0 8px;
    line-height: 1.6;
  }

  .pp__empty-hint {
    opacity: 0.5;
    font-size: 0.82rem !important;
  }

  /* ═══════════════════════════════════════
     Animations
  ═══════════════════════════════════════ */
  @keyframes ppSlideIn {
    from {
      opacity: 0;
      transform: translateY(12px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* ═══════════════════════════════════════
     MOBILE
  ═══════════════════════════════════════ */
  @media screen and (max-width: 749px) {
    .pp {
      min-height: 100vh;
      min-height: 100dvh;
      align-items: stretch;
    }

    .pp__inner {
      display: flex;
      flex-direction: column;
      justify-content: center;
      padding: 24px var(--padding-lg);
    }

    .pp__layout {
      grid-template-columns: 1fr;
      grid-template-rows: auto auto;
      gap: 20px;
      min-height: auto;
    }

    /* ── Package first on mobile (it's the star) ── */
    .pp__package { order: 1; }
    .pp__single { order: 2; }

    /* ── Single becomes a compact horizontal strip ── */
    .pp__single-card.is-active {
      display: flex;
      align-items: center;
    }

    .pp__single-link {
      display: flex;
      align-items: center;
      gap: 14px;
      width: 100%;
    }

    .pp__single-img-wrap {
      width: 80px;
      min-width: 80px;
      aspect-ratio: 1;
      border-radius: var(--product-corner-radius, 0);
    }

    .pp__single-overlay {
      position: static;
      background: none;
      padding: 0;
    }

    .pp__single-overlay-label {
      color: var(--color-foreground);
      opacity: 0.4;
    }

    .pp__single-overlay-title {
      color: var(--color-foreground-heading);
      font-size: 0.82rem;
    }

    .pp__single-overlay-price {
      color: var(--color-foreground);
      opacity: 0.5;
    }

    .pp__connector {
      display: none;
    }

    /* ── Package image taller on mobile ── */
    .pp__package-img-wrap {
      aspect-ratio: 3 / 4;
    }

    /* ── Nav horizontal on mobile ── */
    .pp__nav--prev,
    .pp__nav--next {
      flex-direction: row;
    }

    .pp__nav--prev {
      border-radius: var(--product-corner-radius, 0);
      border-bottom: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
      margin-bottom: 4px;
    }

    .pp__nav--next {
      border-radius: var(--product-corner-radius, 0);
      border-top: 1px solid rgb(var(--color-foreground-rgb) / 0.1);
      margin-top: 4px;
    }

    .pp__nav--prev svg { transform: rotate(-90deg); }
    .pp__nav--next svg { transform: rotate(-90deg); }

    /* ── Scale down decorative elements ── */
    .pp__float--1 { width: 160px; height: 160px; }
    .pp__float--2 { width: 100px; height: 100px; }
    .pp__dot-grid--right { display: none; }
    .pp__dot-grid--left { width: 60px; height: 60px; }

    .pp__note {
      margin-top: 20px;
      font-size: 0.68rem;
    }
  }

  /* ── Very small screens ── */
  @media screen and (max-width: 399px) {
    .pp__single-img-wrap {
      width: 64px;
      min-width: 64px;
    }

    .pp__nav {
      padding: 10px 16px;
      font-size: 0.62rem;
    }
  }
{% endstylesheet %}

