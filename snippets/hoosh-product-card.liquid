{% doc %}
  HOOSH product card — matches hooshwave.com style.
  Dark card, centered product on violet mist, name, red price, gradient Add-to-Cart pill.
  @param {object} product - Shopify product object.
  @param {object} [bundle_product] - Optional paired bundle product (opens via modal trigger).
  @param {string} [bundle_label] - Label for the bundle toggle (e.g. "Pack of 10").
  @param {string} [fallback_name]
  @param {string} [fallback_desc]
{% enddoc %}

{% liquid
  assign p_name = product.title | default: fallback_name | default: 'Product Name'
  assign p_img = product.featured_image
  assign p_type = product.type | default: ''
  assign p_available = product.available
  assign coming_soon = false
  if product.tags contains 'coming-soon' or product.tags contains 'ochakvai-skoro'
    assign coming_soon = true
  endif
  assign variant = product.selected_or_first_available_variant
  assign p_url = product.url | default: '#'
%}

{%- capture p_images_json -%}
[{%- for image in product.images -%}"{{ image | image_url: width: 800 }}"{% unless forloop.last %},{% endunless %}{%- endfor -%}]
{%- endcapture -%}

{%- if bundle_product != blank -%}
  {%- capture b_images_json -%}
  [{%- for image in bundle_product.images -%}"{{ image | image_url: width: 800 }}"{% unless forloop.last %},{% endunless %}{%- endfor -%}]
  {%- endcapture -%}
{%- endif -%}

<article class="hp-card h-reveal">
  <button
    type="button"
    class="hp-card__media"
    data-modal-trigger
    data-product-name="{{ p_name | escape }}"
    data-product-label="{{ p_type | escape }}"
    data-product-desc="{{ product.description | escape }}"
    data-product-img="{{ p_img | image_url: width: 800 }}"
    data-product-images='{{ p_images_json }}'
    {%- if bundle_product != blank %}
    data-bundle-name="{{ bundle_product.title | escape }}"
    data-bundle-desc="{{ bundle_product.description | escape }}"
    data-bundle-img="{{ bundle_product.featured_image | image_url: width: 800 }}"
    data-bundle-images='{{ b_images_json }}'
    data-bundle-label="{{ bundle_label | default: 'Pack of 10' | escape }}"
    {%- endif %}
    aria-label="Виж {{ p_name | escape }}"
  >
    {%- if p_img != blank -%}
      <img
        src="{{ p_img | image_url: width: 600 }}"
        srcset="{{ p_img | image_url: width: 400 }} 400w, {{ p_img | image_url: width: 600 }} 600w"
        sizes="(min-width: 1024px) 25vw, (min-width: 768px) 33vw, 90vw"
        alt="{{ p_img.alt | default: p_name | escape }}"
        loading="lazy"
        width="{{ p_img.width }}"
        height="{{ p_img.height }}"
      >
    {%- else -%}
      <div class="hp-card__placeholder">
        {{ 'product-1' | placeholder_svg_tag }}
      </div>
    {%- endif -%}

    {%- if coming_soon -%}
      <span class="hp-card__soon" aria-hidden="true">Очаквай Скоро</span>
    {%- endif -%}
  </button>

  <h3 class="hp-card__name">{{ p_name }}</h3>

  {%- if product.price and coming_soon == false -%}
    <div class="hp-card__price">{{ product.price | money }}</div>
  {%- else -%}
    <div class="hp-card__price hp-card__price--empty">&nbsp;</div>
  {%- endif -%}

  {%- if coming_soon -%}
    <a href="{{ p_url }}" class="hp-card__cta hp-card__cta--muted">Read More</a>
  {%- elsif p_available -%}
    {%- form 'product', product, class: 'hp-card__form' -%}
      <input type="hidden" name="id" value="{{ variant.id }}">
      <button type="submit" class="hp-card__cta" {% unless variant.available %}disabled{% endunless %}>
        Add To Cart
      </button>
    {%- endform -%}
  {%- else -%}
    <a href="{{ p_url }}" class="hp-card__cta hp-card__cta--muted">Read More</a>
  {%- endif -%}
</article>

<style>
  .hp-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    background: transparent;
    text-align: center;
    position: relative;
    padding: 0 8px;
  }

  .hp-card__media {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 3 / 4;
    border-radius: 18px;
    overflow: hidden;
    cursor: pointer;
    background:
      radial-gradient(ellipse at 50% 75%, rgba(165, 75, 200, 0.45), transparent 65%),
      radial-gradient(ellipse at 50% 30%, rgba(60, 30, 100, 0.4), transparent 70%),
      #14121a;
    border: none;
    padding: 0;
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .hp-card__media:hover {
    transform: translateY(-4px);
  }
  .hp-card__media img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 10% 10% 8%;
  }
  .hp-card__placeholder {
    width: 50%;
    margin: 25% auto;
    opacity: 0.15;
  }
  .hp-card__soon {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--h-font-display, 'Bebas Neue', sans-serif);
    font-size: clamp(1.2rem, 2.4vw, 2rem);
    color: rgba(255, 255, 255, 0.85);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    transform: rotate(-20deg);
    pointer-events: none;
    text-shadow: 0 4px 16px rgba(0, 0, 0, 0.7);
  }

  .hp-card__name {
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    font-size: clamp(0.95rem, 1.3vw, 1.1rem);
    font-weight: 500;
    color: var(--h-text, #fff);
    margin: 8px 0 0;
    line-height: 1.3;
    min-height: 2.6em;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .hp-card__price {
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    font-size: clamp(1.2rem, 1.8vw, 1.6rem);
    font-weight: 700;
    color: #ff2e4a;
    margin: 0 0 6px;
    letter-spacing: 0.01em;
  }
  .hp-card__price--empty { visibility: hidden; }

  .hp-card__form { width: 100%; }

  .hp-card__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 44px;
    padding: 10px 24px;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    text-decoration: none;
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: #fff;
    background: linear-gradient(90deg, #ff4e7e 0%, #e84a7a 35%, #8a5bff 100%);
    transition: transform 0.2s ease, filter 0.2s ease, opacity 0.2s ease;
  }
  .hp-card__cta:hover:not(:disabled) {
    transform: translateY(-1px);
    filter: brightness(1.07);
  }
  .hp-card__cta:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .hp-card__cta--muted {
    background: linear-gradient(90deg, #5e6270 0%, #8a5bff 100%);
    opacity: 0.85;
  }
</style>
