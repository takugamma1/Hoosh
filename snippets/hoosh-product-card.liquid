{% doc %}
  HOOSH product card — opens full-screen product view.
  @param {object} product - Shopify product object.
  @param {string} [fallback_name]
  @param {string} [fallback_desc]
{% enddoc %}

{% liquid
  assign p_name = product.title | default: fallback_name | default: 'Product Name'
  assign p_desc = product.description | default: fallback_desc | default: 'Premium electric shisha device'
  assign p_img = product.featured_image
  assign p_type = product.type | default: ''
%}

{%- capture p_images_json -%}
[
  {%- for image in product.images -%}
    "{{ image | image_url: width: 800 }}"{% unless forloop.last %},{% endunless %}
  {%- endfor -%}
]
{%- endcapture -%}

<div class="hoosh-card h-reveal">
  <button
    class="hoosh-card__trigger"
    data-modal-trigger
    data-product-name="{{ p_name | escape }}"
    data-product-label="{{ p_type | escape }}"
    data-product-desc="{{ product.description | escape }}"
    data-product-img="{{ p_img | image_url: width: 800 }}"
    data-product-images='{{ p_images_json }}'
    aria-label="View {{ p_name }}"
  >
    <div class="hoosh-card__image">
      {%- if p_img != blank -%}
        <img
          src="{{ p_img | image_url: width: 600 }}"
          srcset="{{ p_img | image_url: width: 400 }} 400w, {{ p_img | image_url: width: 600 }} 600w"
          sizes="(min-width: 1024px) 33vw, (min-width: 768px) 50vw, 90vw"
          alt="{{ p_img.alt | default: p_name | escape }}"
          loading="lazy"
          width="{{ p_img.width }}"
          height="{{ p_img.height }}"
        >
      {%- else -%}
        <div class="hoosh-card__placeholder">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
      {%- endif -%}
    </div>
    <div class="hoosh-card__info">
      <h3 class="hoosh-card__name">{{ p_name }}</h3>
      <span class="hoosh-card__view">View Details <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg></span>
    </div>
  </button>
</div>

<style>
  .hoosh-card {
    background: var(--h-bg-card);
    border: 1px solid var(--h-border);
    border-radius: var(--h-card-radius);
    overflow: hidden;
    transition: transform 0.4s var(--h-ease), border-color 0.4s ease;
  }
  .hoosh-card:hover {
    transform: translateY(-4px);
    border-color: rgba(255, 20, 147, 0.2);
  }
  .hoosh-card__trigger {
    display: block;
    width: 100%;
    background: none;
    border: none;
    padding: 0;
    cursor: pointer;
    text-align: left;
    color: inherit;
  }
  .hoosh-card__image {
    aspect-ratio: 4 / 5;
    background: var(--h-bg);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hoosh-card__image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 8%;
  }
  .hoosh-card__placeholder {
    width: 60%;
    opacity: 0.1;
  }
  .hoosh-card__info {
    padding: 20px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
  }
  .hoosh-card__name {
    font-family: var(--h-font-display);
    font-size: var(--h-product-name);
    color: var(--h-text);
    text-transform: uppercase;
    letter-spacing: var(--h-tracking-tight);
    margin: 0;
    line-height: 1.1;
  }
  .hoosh-card__view {
    font-family: var(--h-font-body);
    font-size: var(--h-small);
    color: var(--h-text-muted);
    display: flex;
    align-items: center;
    gap: 6px;
    white-space: nowrap;
    transition: color 0.2s;
    flex-shrink: 0;
  }
  .hoosh-card:hover .hoosh-card__view {
    color: var(--h-pink);
  }
</style>
