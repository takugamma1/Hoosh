{% doc %}
  HOOSH product card — simple link-to-product card.
  Dark media tile with violet mist, title, and a "Свържете се с нас" CTA.
  @param {object} [product] - Shopify product object.
  @param {string} [fallback_name]
{% enddoc %}

{% liquid
  assign p_name = product.title | default: fallback_name | default: 'Product Name'
  assign p_img = product.featured_image
  assign coming_soon = false
  if product.tags contains 'coming-soon' or product.tags contains 'ochakvai-skoro'
    assign coming_soon = true
  endif
  assign p_url = product.url | default: '#'
%}

<article class="hp-card h-reveal">
  <a class="hp-card__media" href="{{ p_url }}" aria-label="{{ p_name | escape }}">
    {%- if p_img != blank -%}
      <img
        src="{{ p_img | image_url: width: 600 }}"
        srcset="{{ p_img | image_url: width: 400 }} 400w, {{ p_img | image_url: width: 600 }} 600w"
        sizes="(min-width: 1024px) 25vw, (min-width: 768px) 33vw, 90vw"
        alt="{{ p_img.alt | default: p_name | escape }}"
        loading="lazy"
        width="{{ p_img.width }}"
        height="{{ p_img.height }}"
      >
    {%- else -%}
      <div class="hp-card__placeholder">
        {{ 'product-1' | placeholder_svg_tag }}
      </div>
    {%- endif -%}

    {%- if coming_soon -%}
      <span class="hp-card__soon" aria-hidden="true">Очаквай Скоро</span>
    {%- endif -%}
  </a>

  <a class="hp-card__name-link" href="{{ p_url }}">
    <h3 class="hp-card__name">{{ p_name }}</h3>
  </a>

  <a href="{{ p_url }}" class="hp-card__cta">Свържете се с нас</a>
</article>

<style>
  .hp-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    background: transparent;
    text-align: center;
    position: relative;
    padding: 0 8px;
  }

  .hp-card__media {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 3 / 4;
    border-radius: 18px;
    overflow: hidden;
    text-decoration: none;
    background:
      radial-gradient(ellipse at 50% 75%, rgba(165, 75, 200, 0.45), transparent 65%),
      radial-gradient(ellipse at 50% 30%, rgba(60, 30, 100, 0.4), transparent 70%),
      #14121a;
    border: none;
    padding: 0;
    transition: transform 0.35s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .hp-card__media:hover {
    transform: translateY(-4px);
  }
  .hp-card__media img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    padding: 10% 10% 8%;
  }
  .hp-card__placeholder {
    width: 50%;
    margin: 25% auto;
    opacity: 0.15;
  }
  .hp-card__soon {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--h-font-display, 'Bebas Neue', sans-serif);
    font-size: clamp(1.2rem, 2.4vw, 2rem);
    color: rgba(255, 255, 255, 0.85);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    transform: rotate(-20deg);
    pointer-events: none;
    text-shadow: 0 4px 16px rgba(0, 0, 0, 0.7);
  }

  .hp-card__name-link {
    text-decoration: none;
    color: inherit;
    width: 100%;
  }
  .hp-card__name {
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    font-size: clamp(0.95rem, 1.3vw, 1.1rem);
    font-weight: 500;
    color: var(--h-text, #fff);
    margin: 8px 0 0;
    line-height: 1.3;
    min-height: 2.6em;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
  }

  .hp-card__price {
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    font-size: clamp(1.2rem, 1.8vw, 1.6rem);
    font-weight: 700;
    color: #ff2e4a;
    margin: 0 0 6px;
    letter-spacing: 0.01em;
  }
  .hp-card__price--empty { visibility: hidden; }

  .hp-card__form { width: 100%; }

  .hp-card__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 44px;
    padding: 10px 24px;
    border: none;
    border-radius: 999px;
    cursor: pointer;
    text-decoration: none;
    font-family: var(--h-font-body, 'Outfit', sans-serif);
    font-size: 0.9rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: #fff;
    background: linear-gradient(90deg, #ff4e7e 0%, #e84a7a 35%, #8a5bff 100%);
    transition: transform 0.2s ease, filter 0.2s ease, opacity 0.2s ease;
  }
  .hp-card__cta:hover:not(:disabled) {
    transform: translateY(-1px);
    filter: brightness(1.07);
  }
  .hp-card__cta:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }
  .hp-card__cta--muted {
    background: linear-gradient(90deg, #5e6270 0%, #8a5bff 100%);
    opacity: 0.85;
  }
</style>
