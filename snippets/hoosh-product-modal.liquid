{% doc %}
  HOOSH Full-Screen Product View.
  Desktop: product images left, info + contact right.
  Mobile: full screen, compact, minimal scroll.
  @param {string} whatsapp
  @param {string} telegram
  @param {string} phone
{% enddoc %}

<div id="hoosh-modal" class="hm" aria-hidden="true" role="dialog" aria-modal="true">
  <div class="hm__overlay" data-modal-overlay></div>

  <div class="hm__panel">
    {%- comment -%} Close button {%- endcomment -%}
    <button class="hm__close" data-modal-close aria-label="Close">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>

    {%- comment -%} LEFT: Product gallery {%- endcomment -%}
    <div class="hm__gallery">
      <div class="hm__main-img">
        <img data-modal-img src="" alt="" loading="lazy">
      </div>
      <div class="hm__thumbs" data-modal-thumbs></div>
    </div>

    {%- comment -%} RIGHT: Info + Contact {%- endcomment -%}
    <div class="hm__info">
      <div class="hm__info-top">
        <span class="h-label hm__label" data-modal-label></span>
        <h2 class="h-display hm__name" data-modal-name></h2>
        <hr class="h-divider">
        <div class="h-body hm__desc" data-modal-desc></div>
      </div>

      <div class="hm__contact">
        <p class="hm__contact-title">Order from Official Distributor</p>
        <div class="hm__contact-row">
          {%- if whatsapp != blank -%}
            <a
              href="https://wa.me/{{ whatsapp }}"
              target="_blank"
              rel="noopener"
              class="hm__contact-btn hm__contact-btn--wa"
              data-modal-wa
              data-wa-base="https://wa.me/{{ whatsapp }}"
              aria-label="Order via WhatsApp"
            >
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51l-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              <span>WhatsApp</span>
            </a>
          {%- endif -%}
          {%- if phone != blank -%}
            <a
              href="tel:{{ phone }}"
              class="hm__contact-btn hm__contact-btn--ph"
              aria-label="Call to order"
            >
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07 19.5 19.5 0 01-6-6 19.79 19.79 0 01-3.07-8.67A2 2 0 014.11 2h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L8.09 9.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
              <span>Call Us</span>
            </a>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  /* ── Full-screen modal ── */
  .hm {
    position: fixed;
    inset: 0;
    z-index: 9999;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.35s var(--h-ease, ease), visibility 0.35s;
  }
  .hm.is-open {
    opacity: 1;
    visibility: visible;
  }

  .hm__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
  }

  .hm__panel {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1fr 1fr;
    width: 100%;
    height: 100%;
    background: var(--h-bg, #000);
    transform: scale(0.97);
    transition: transform 0.4s var(--h-ease, ease);
  }
  .hm.is-open .hm__panel {
    transform: scale(1);
  }

  /* Close */
  .hm__close {
    position: absolute;
    top: 20px;
    right: 24px;
    z-index: 10;
    background: rgba(255,255,255,0.08);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 50%;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--h-text, #fff);
    cursor: pointer;
    transition: background 0.2s, border-color 0.2s;
  }
  .hm__close:hover {
    background: rgba(255,255,255,0.15);
    border-color: rgba(255,255,255,0.25);
  }

  /* Gallery (left) */
  .hm__gallery {
    display: flex;
    flex-direction: column;
    background: var(--h-bg-elevated, #0a0a0a);
    overflow: hidden;
  }
  .hm__main-img {
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 5%;
    min-height: 0;
  }
  .hm__main-img img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
  }
  .hm__thumbs {
    display: flex;
    gap: 8px;
    padding: 12px 24px 20px;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .hm__thumbs::-webkit-scrollbar { display: none; }
  .hm__thumb {
    width: 64px;
    height: 64px;
    border-radius: 8px;
    border: 2px solid transparent;
    background: var(--h-bg, #000);
    cursor: pointer;
    flex-shrink: 0;
    overflow: hidden;
    transition: border-color 0.2s;
    padding: 4px;
  }
  .hm__thumb.is-active {
    border-color: var(--h-pink, #FF1493);
  }
  .hm__thumb img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  /* Info (right) */
  .hm__info {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: clamp(2rem, 4vw, 4rem);
    overflow-y: auto;
  }
  .hm__info-top {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .hm__label {
    color: var(--h-green, #00E676);
  }
  .hm__name {
    font-size: clamp(1.8rem, 4vw, 3rem);
    margin: 0;
  }
  .hm__desc {
    color: var(--h-text-secondary, #888);
    line-height: 1.7;
    margin: 0;
    max-width: 480px;
  }

  /* Contact bar */
  .hm__contact {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--h-border-accent, #333);
  }
  .hm__contact-title {
    font-family: var(--h-font-body, sans-serif);
    font-size: var(--h-small, 0.85rem);
    color: var(--h-text-muted, #555);
    text-transform: uppercase;
    letter-spacing: var(--h-tracking-wide, 0.15em);
    margin: 0 0 16px;
  }
  .hm__contact-row {
    display: flex;
    gap: 12px;
  }
  .hm__contact-btn {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 14px 28px;
    border-radius: var(--h-btn-radius, 50px);
    font-family: var(--h-font-body, sans-serif);
    font-size: 0.95rem;
    font-weight: 500;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
    flex: 1;
    justify-content: center;
  }
  .hm__contact-btn:hover {
    transform: translateY(-2px);
  }
  .hm__contact-btn--wa {
    background: var(--h-whatsapp, #25D366);
    color: #fff;
  }
  .hm__contact-btn--wa:hover {
    box-shadow: 0 8px 24px rgba(37, 211, 102, 0.3);
  }
  .hm__contact-btn--ph {
    background: transparent;
    color: var(--h-text, #fff);
    border: 1px solid var(--h-border-accent, #333);
  }
  .hm__contact-btn--ph:hover {
    border-color: var(--h-text-secondary, #888);
    box-shadow: 0 8px 24px rgba(255,255,255,0.05);
  }

  /* ── MOBILE: full screen, compact, minimal scroll ── */
  @media screen and (max-width: 767px) {
    .hm__panel {
      grid-template-columns: 1fr;
      grid-template-rows: 45vh 1fr;
    }
    .hm__gallery {
      border-bottom: 1px solid var(--h-border, #1a1a1a);
    }
    .hm__main-img {
      padding: 8%;
    }
    .hm__thumbs {
      padding: 8px 16px 12px;
    }
    .hm__thumb {
      width: 48px;
      height: 48px;
    }
    .hm__info {
      padding: 20px 20px 24px;
      overflow-y: auto;
    }
    .hm__name {
      font-size: 1.5rem;
    }
    .hm__desc {
      font-size: 0.85rem;
      -webkit-line-clamp: 4;
      display: -webkit-box;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .hm__contact {
      margin-top: 16px;
      padding-top: 16px;
    }
    .hm__contact-row {
      flex-direction: column;
    }
    .hm__contact-btn {
      padding: 14px 20px;
    }
    .hm__close {
      top: 12px;
      right: 12px;
      width: 38px;
      height: 38px;
    }
  }

  /* Large desktop: limit panel width */
  @media screen and (min-width: 1440px) {
    .hm__panel {
      max-width: 1400px;
      max-height: 900px;
      margin: auto;
      border-radius: 16px;
      overflow: hidden;
      height: auto;
    }
    .hm__gallery {
      min-height: 600px;
    }
  }
</style>
